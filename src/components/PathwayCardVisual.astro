---
import StepByStep from './StepByStep.astro';
import PathwayIcon from './PathwayIcon.astro';
import PathwayTimeHorizon from './PathwayTimeHorizon.astro';
import { iconStyleMap } from '../data/pathway-cards';
import type { PathwayCard } from '../data/pathway-cards';

interface Props extends PathwayCard {}

const { id, icon, title, bestFor, accentColor, badge, oneLiner, isCrisis, facts, steps, timeHorizon, progressive } = Astro.props;

const bgClass = isCrisis ? 'bg-primary-light' : 'bg-paper-cream';
const accentTopBorder = accentColor.replace('border-l-', 'border-t-');
const iconStyle = iconStyleMap[icon] ?? { bg: 'bg-primary-light', stroke: 'text-primary' };
---

<div id={id} data-pathway-card data-progressive-card={progressive ? '' : undefined} class={`pathway-card-clickable rounded-xl shadow-sm border-t-4 ${accentTopBorder} ${bgClass} p-6 md:p-8 flex flex-col`}>
  <div class="pathway-card-inner flex flex-col">
  {/* Icon */}
  <div class={`w-12 h-12 ${iconStyle.bg} rounded-xl flex items-center justify-center mb-5`}>
    <PathwayIcon icon={icon} class={`w-6 h-6 ${iconStyle.stroke}`} />
  </div>

  {/* Badge + Title */}
  <div class="mb-3">
    {badge && (
      <span class="inline-block text-xs font-semibold text-white bg-primary px-3 py-1 rounded-full mb-2">{badge}</span>
    )}
    <h3 class="text-xl md:text-2xl font-bold text-heading leading-snug">{title}</h3>
  </div>

  {/* Progressive disclosure: one-liner, metadata, and steps hidden by default */}
  <details class="pathway-details-toggle">
    <summary class="inline-flex items-center text-sm font-semibold text-primary cursor-pointer select-none hover:text-primary-mid transition-colors">
      <span class="sr-only">{title}: </span>
      <span class="pathway-label-show">Show details</span>
      <span class="pathway-label-hide">Hide details</span>
    </summary>
    <div class="pathway-l1-body mt-5">
      <p class="text-base leading-relaxed text-body mb-5">{oneLiner}</p>
      <div class="flex flex-wrap gap-2 mb-5">
        <span class="inline-flex items-center gap-1.5 text-sm bg-bg-light px-3 py-1.5 rounded-lg">
          <span class="text-body">Cost:</span>
          <span class="font-semibold text-heading">{facts.cost}</span>
        </span>
        <span class="inline-flex items-center gap-1.5 text-sm bg-bg-light px-3 py-1.5 rounded-lg">
          <span class="text-body">Sessions:</span>
          <span class="font-semibold text-heading">{facts.sessions ?? 'Varies'}</span>
        </span>
        <PathwayTimeHorizon events={timeHorizon?.events} />
      </div>
      <p class="text-sm text-body/80 mb-6">{bestFor}</p>
      {progressive ? (
        <details class="pathway-details-toggle pathway-details-toggle--nested">
          <summary class="inline-flex items-center text-sm font-semibold text-primary cursor-pointer select-none hover:text-primary-mid transition-colors">
            <span class="sr-only">{title}: </span>
            <span class="pathway-label-show">How does this work?</span>
            <span class="pathway-label-hide">Hide steps</span>
          </summary>
          <ol class="pathway-step-accordions mt-4" data-step-reveal data-step-total={steps.length}>
            {steps.map((step, idx) => (
              <li id={`${id}-step-${step.number}`} class="scroll-mt-24" data-step-index={step.number} hidden={idx > 0}>
                <details class="pathway-step-item">
                  <summary class="pathway-step-summary">
                    <span class="pathway-step-number" aria-hidden="true">{step.number}</span>
                    <span class="pathway-step-title">{step.title}</span>
                  </summary>
                  <div class="pathway-step-detail prose" set:html={step.detail} />
                </details>
              </li>
            ))}
          </ol>
          <div class="pathway-gp-progress mt-5 pt-4 border-t border-border">
            <p class="text-xs text-body mb-2" id={`${id}-progress-label`} data-progress-label>
              Step 1 of {steps.length}
            </p>
            <div
              class="pathway-gp-progress-track h-1.5 rounded-full bg-bg-light overflow-hidden"
              role="progressbar"
              aria-valuemin="1"
              aria-valuemax={steps.length}
              aria-valuenow="1"
              aria-labelledby={`${id}-progress-label`}
              data-progressbar
            >
              <div
                class="pathway-gp-progress-fill h-full bg-primary pathway-gp-progress-fill-motion"
                style={`width: ${(100 / steps.length).toFixed(4)}%`}
                data-progress-fill
              />
            </div>
            <p class="sr-only" aria-live="polite" aria-atomic="true" data-progress-live></p>
          </div>
        </details>
      ) : (
        <StepByStep steps={steps} />
      )}
    </div>
  </details>
  </div>
</div>

<script>
  import '../scripts/pathway-progressive-steps.ts';
</script>
