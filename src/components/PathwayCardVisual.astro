---
import StepByStep from './StepByStep.astro';
import PathwayIcon from './PathwayIcon.astro';
import { iconStyleMap } from '../data/pathway-cards';
import type { PathwayCard } from '../data/pathway-cards';

interface Props extends PathwayCard {}

const { id, icon, title, bestFor, accentColor, badge, oneLiner, isCrisis, facts, steps } = Astro.props;

const bgClass = isCrisis ? 'bg-primary-light' : 'bg-white';
const accentTopBorder = accentColor.replace('border-l-', 'border-t-');
const iconStyle = iconStyleMap[icon] ?? { bg: 'bg-primary-light', stroke: 'text-primary' };
---

<div id={id} class={`rounded-xl shadow-sm border-t-4 ${accentTopBorder} ${bgClass} p-6 md:p-8 flex flex-col`}>
  {/* Icon */}
  <div class={`w-12 h-12 ${iconStyle.bg} rounded-xl flex items-center justify-center mb-5`}>
    <PathwayIcon icon={icon} class={`w-6 h-6 ${iconStyle.stroke}`} />
  </div>

  {/* Badge + Title */}
  <div class="mb-3">
    {badge && (
      <span class="inline-block text-xs font-semibold text-white bg-primary px-3 py-1 rounded-full mb-2">{badge}</span>
    )}
    <h3 class="text-xl md:text-2xl font-bold text-heading leading-snug">{title}</h3>
  </div>

  {/* One-liner */}
  <p class="text-base leading-relaxed text-body mb-5">{oneLiner}</p>

  {/* Progressive disclosure: details, metadata, and steps hidden by default */}
  <details class="pathway-details-toggle mt-auto">
    <summary class="inline-flex items-center gap-2 text-sm font-semibold text-primary cursor-pointer select-none hover:text-primary-mid transition-colors">
      <span class="pathway-toggle-label"></span>
    </summary>
    <div class="mt-5">
      <div class="flex flex-wrap gap-2 mb-5">
        <span class="inline-flex items-center gap-1.5 text-sm bg-bg-light px-3 py-1.5 rounded-lg">
          <span class="text-body">Cost:</span>
          <span class="font-semibold text-heading">{facts.cost}</span>
        </span>
        <span class="inline-flex items-center gap-1.5 text-sm bg-bg-light px-3 py-1.5 rounded-lg">
          <span class="text-body">Wait:</span>
          <span class="font-semibold text-heading">{facts.wait ?? 'Varies'}</span>
        </span>
        <span class="inline-flex items-center gap-1.5 text-sm bg-bg-light px-3 py-1.5 rounded-lg">
          <span class="text-body">Sessions:</span>
          <span class="font-semibold text-heading">{facts.sessions ?? 'Varies'}</span>
        </span>
      </div>
      <p class="text-sm text-body/80 mb-6">{bestFor}</p>
      <StepByStep steps={steps} />
    </div>
  </details>
</div>
