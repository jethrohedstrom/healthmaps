---
import costsData from '../data/calculator-costs.json';
import Button from './Button.astro';

const practitionerTypes = costsData.practitionerTypes;

const optionCard = 'flex h-full min-h-14 items-center rounded-[10px] border border-ink-green/16 bg-white px-4 py-3 text-base font-semibold leading-snug text-heading transition-colors duration-150 hover:border-primary hover:bg-primary-light peer-checked:border-primary peer-checked:bg-primary-light peer-checked:ring-1 peer-checked:ring-primary peer-focus-visible:ring-2 peer-focus-visible:ring-primary';
const stepperButton = 'h-11 w-11 shrink-0 rounded-[10px] border border-ink-green/16 bg-white text-xl font-semibold text-heading transition-colors duration-150 hover:border-primary hover:bg-primary-light disabled:pointer-events-none disabled:opacity-40';
---
<div id="cost-calculator" class="bg-white rounded-xl shadow-sm p-8 md:p-10">
  <form id="calc-form" class="space-y-6" aria-label="Mental health cost calculator">

    <!-- Practitioner type -->
    <fieldset>
      <legend class="block text-sm font-semibold text-body mb-2">
        Type of practitioner
      </legend>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        {practitionerTypes.map((p, i) => (
          <label class="cursor-pointer">
            <input
              type="radio"
              name="practitionerType"
              value={p.id}
              checked={i === 0}
              class="peer sr-only"
            />
            <span class={optionCard}>{p.label}</span>
          </label>
        ))}
      </div>
    </fieldset>

    <!-- Session fee -->
    <div>
      <label for="session-fee" class="block text-sm font-semibold text-body mb-1">
        Session fee ($)
      </label>
      <input
        type="number"
        id="session-fee"
        name="sessionFee"
        min="0"
        max="1000"
        step="5"
        placeholder="e.g. 220"
        class="w-full border border-border rounded-[10px] px-4 py-2.5 text-body bg-white hover:border-primary/50 transition-colors focus:ring-2 focus:ring-primary focus:border-primary"
      />
      <p id="fee-hint" class="text-xs text-body mt-1">Typical range: loading...</p>
    </div>

    <!-- Number of sessions -->
    <div>
      <label for="num-sessions" class="block text-sm font-semibold text-body mb-1">
        Number of sessions
      </label>
      <div class="flex items-center gap-3">
        <button type="button" id="sessions-minus" aria-label="Fewer sessions" class={stepperButton}>&minus;</button>
        <input
          type="number"
          id="num-sessions"
          name="numSessions"
          min="1"
          max="10"
          value="10"
          inputmode="numeric"
          class="h-11 w-20 rounded-[10px] border border-ink-green/16 bg-white text-center text-base font-semibold text-heading transition-colors focus:border-primary focus:ring-2 focus:ring-primary [appearance:textfield] [&::-webkit-inner-spin-button]:appearance-none [&::-webkit-outer-spin-button]:appearance-none"
        />
        <button type="button" id="sessions-plus" aria-label="More sessions" class={stepperButton}>+</button>
      </div>
      <p class="text-xs text-body mt-1">Medicare rebates cover up to 10 sessions per calendar year.</p>
    </div>

    <!-- GP bulk-billed? -->
    <fieldset>
      <legend class="block text-sm font-semibold text-body mb-2">
        Is your GP bulk-billed?
      </legend>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        <label class="cursor-pointer">
          <input type="radio" name="gpBilling" value="yes" checked class="peer sr-only" />
          <span class={optionCard}>Yes, no out-of-pocket cost for GP visits</span>
        </label>
        <label class="cursor-pointer">
          <input type="radio" name="gpBilling" value="no" class="peer sr-only" />
          <span class={optionCard}>No, I pay a gap fee (~$40)</span>
        </label>
      </div>
    </fieldset>

    <!-- Calculate button -->
    <Button type="submit" size="lg" class="w-full">Calculate My Costs</Button>
  </form>

  <!-- Results -->
  <div id="calc-results" class="hidden mt-8 pt-6 border-t border-border">
    <h3 class="text-lg font-bold text-heading mb-4">Estimated Costs</h3>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
      <div class="bg-bg-light rounded-lg p-4">
        <p class="text-body mb-1">Total session fees</p>
        <p id="result-total-fees" class="text-2xl font-bold text-body">$0</p>
      </div>
      <div class="bg-bg-light rounded-lg p-4">
        <p class="text-body mb-1">Total Medicare rebate</p>
        <p id="result-total-rebate" class="text-2xl font-bold text-primary">−$0</p>
      </div>
      <div class="bg-bg-light rounded-lg p-4">
        <p class="text-body mb-1">GP visit costs</p>
        <p id="result-gp-cost" class="text-2xl font-bold text-body">$0</p>
      </div>
      <div class="bg-bg-light rounded-lg p-4 border-2 border-heading">
        <p class="text-heading font-medium mb-1">Your out-of-pocket cost</p>
        <p id="result-oop" class="text-2xl font-bold text-heading">$0</p>
      </div>
    </div>

    <div id="result-breakdown" class="mt-4 text-sm text-body space-y-1"></div>

    <p class="mt-4 text-xs text-body">
      These are estimates only. Medicare rebate amounts may have changed; check
      <a href="https://www.servicesaustralia.gov.au/medicare" class="underline hover:text-primary transition-colors" target="_blank" rel="noopener">Services Australia</a>
      for current rates. Last updated: {costsData.lastUpdated}.
    </p>
  </div>
</div>

<script is:inline define:vars={{ practitionerTypes: costsData.practitionerTypes, feeRanges: costsData.sessionFeeRanges, gpCostPrivate: costsData.gpCostPrivate }}>
  const form = document.getElementById('calc-form');
  const feeInput = document.getElementById('session-fee');
  const feeHint = document.getElementById('fee-hint');
  const sessionsInput = document.getElementById('num-sessions');
  const minusBtn = document.getElementById('sessions-minus');
  const plusBtn = document.getElementById('sessions-plus');
  const resultsDiv = document.getElementById('calc-results');

  const MIN_SESSIONS = 1;
  const MAX_SESSIONS = 10;

  function getSessions() {
    const v = parseInt(sessionsInput.value);
    if (isNaN(v)) return MAX_SESSIONS;
    return Math.min(MAX_SESSIONS, Math.max(MIN_SESSIONS, v));
  }

  function setSessions(v) {
    sessionsInput.value = v;
    minusBtn.disabled = v <= MIN_SESSIONS;
    plusBtn.disabled = v >= MAX_SESSIONS;
  }

  minusBtn.addEventListener('click', () => setSessions(Math.max(MIN_SESSIONS, getSessions() - 1)));
  plusBtn.addEventListener('click', () => setSessions(Math.min(MAX_SESSIONS, getSessions() + 1)));
  sessionsInput.addEventListener('change', () => setSessions(getSessions()));
  setSessions(getSessions());

  function updateFeeHint() {
    const type = form.elements.practitionerType.value;
    const range = feeRanges[type];
    if (range) {
      feeHint.textContent = `Typical range: $${range.low}–$${range.high}`;
      if (!feeInput.value) {
        feeInput.placeholder = `e.g. ${range.mid}`;
      }
    }
  }

  form.addEventListener('change', (e) => {
    if (e.target.name === 'practitionerType') updateFeeHint();
  });
  updateFeeHint();

  form.addEventListener('submit', function(e) {
    e.preventDefault();

    const type = form.elements.practitionerType.value;
    const sessionFee = parseFloat(feeInput.value);
    const numSessions = getSessions();
    const gpBulkBilled = form.elements.gpBilling.value === 'yes';

    if (isNaN(sessionFee) || sessionFee <= 0) {
      feeInput.focus();
      feeInput.setCustomValidity('Please enter a valid session fee.');
      feeInput.reportValidity();
      feeInput.setCustomValidity('');
      return;
    }

    const prac = practitionerTypes.find(p => p.id === type);
    const rebatePerSession = prac ? prac.rebatePerSession : 0;

    const totalFees = sessionFee * numSessions;
    const totalRebate = rebatePerSession * numSessions;

    // GP costs: initial MHCP/referral appointment, plus the after-6-sessions
    // review — but only MHCP pathways have that review (psychiatrists don't).
    const requiresMHCP = prac ? prac.requiresMHCP : true;
    let gpVisits = 1; // Initial MHCP or referral
    if (requiresMHCP && numSessions > 6) gpVisits = 2; // + review
    const gpCostPerVisit = gpBulkBilled ? 0 : gpCostPrivate;
    const totalGpCost = gpVisits * gpCostPerVisit;

    const outOfPocket = totalFees - totalRebate + totalGpCost;

    document.getElementById('result-total-fees').textContent = `$${totalFees.toFixed(2)}`;
    document.getElementById('result-total-rebate').textContent = `−$${totalRebate.toFixed(2)}`;
    document.getElementById('result-gp-cost').textContent = `$${totalGpCost.toFixed(2)}`;
    document.getElementById('result-oop').textContent = `$${Math.max(0, outOfPocket).toFixed(2)}`;

    const gapPerSession = sessionFee - rebatePerSession;
    const breakdown = document.getElementById('result-breakdown');
    breakdown.innerHTML = `
      <p><strong>Per session:</strong> $${sessionFee.toFixed(2)} fee − $${rebatePerSession.toFixed(2)} rebate = <strong>$${Math.max(0, gapPerSession).toFixed(2)} gap</strong></p>
      <p><strong>GP visits:</strong> ${gpVisits} (${requiresMHCP ? 'MHCP' : 'referral'}${gpVisits > 1 ? ' + review' : ''})${gpBulkBilled ? ' (bulk-billed)' : ` × $${gpCostPerVisit}`}</p>
    `;

    resultsDiv.classList.remove('hidden');
    resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });
</script>
