---
import costsData from '../data/calculator-costs.json';

const practitionerTypes = costsData.practitionerTypes;
const feeRanges = costsData.sessionFeeRanges as Record<string, { low: number; mid: number; high: number }>;

const optionCard = 'flex h-full min-h-14 items-center rounded-[10px] border border-ink-green/16 bg-white px-4 py-3 text-base font-semibold leading-snug text-heading transition-colors duration-150 hover:border-primary hover:bg-primary-light peer-checked:border-primary peer-checked:bg-primary-light peer-checked:ring-1 peer-checked:ring-primary peer-focus-visible:ring-2 peer-focus-visible:ring-primary';

// Receipt row: label · dotted leader · amount. The empty leader span is a
// baseline-aligned flex item, so its bottom border sits on the text baseline.
const receiptRow = 'flex items-baseline gap-2 text-[15px] leading-snug';
const receiptLeader = 'min-w-4 flex-1 border-b border-dotted border-ink-green/25';

// SSR the default estimate (first practitioner, typical fee, bulk-billed GP)
// so the receipt is meaningful before/without JS. The maths mirrors
// src/scripts/cost-calculator.ts exactly.
const defaultPrac = practitionerTypes[0];
const defaultRange = feeRanges[defaultPrac.id];
const defaultFee = defaultRange.mid;

const aud = new Intl.NumberFormat('en-AU', { style: 'currency', currency: 'AUD' });
const audWhole = new Intl.NumberFormat('en-AU', { style: 'currency', currency: 'AUD', minimumFractionDigits: 0, maximumFractionDigits: 0 });
const ssrFeeLabel = Number.isInteger(defaultFee) ? audWhole.format(defaultFee) : aud.format(defaultFee);

const ssrRebate = defaultPrac.rebatePerSession;
const ssrGpCost = 0; // bulk-billed default
const ssrPerSession = Math.max(0, defaultFee - ssrRebate);
---
<div id="cost-calculator" class="bg-paper-cream border border-pencil rounded-[14px] p-6 sm:p-8 md:p-10">
  <div class="grid gap-8 md:grid-cols-[1fr_minmax(280px,0.85fr)] md:gap-10">
    <form id="calc-form" class="space-y-6" aria-label="Mental health cost calculator" novalidate>

      <!-- Practitioner type -->
      <fieldset>
        <legend class="block text-sm font-semibold text-body mb-2">
          Type of practitioner
        </legend>
        <!-- REVIEW: AI-drafted — check the clinical vs general psychologist framing against src/content/practitioners/psychologist.md. -->
        <p class="text-xs text-body mb-3">
          Clinical psychologists have extra postgraduate training, which is why their rebate is higher — general psychologists are equally registered and well suited to common concerns like anxiety or depression.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          {practitionerTypes.map((p, i) => (
            <label class="cursor-pointer">
              <input
                type="radio"
                name="practitionerType"
                value={p.id}
                checked={i === 0}
                class="peer sr-only"
              />
              <span class={optionCard}>
                <span class="block">
                  {p.label}
                  <span class="mt-0.5 block text-[13px] font-normal leading-snug text-meta-sage">
                    Rebate ${p.rebatePerSession.toFixed(2)} per session
                  </span>
                </span>
              </span>
            </label>
          ))}
        </div>
      </fieldset>

      <!-- Session fee -->
      <div>
        <label for="session-fee" class="block text-sm font-semibold text-body mb-1">
          Session fee ($)
        </label>
        <input
          type="number"
          id="session-fee"
          name="sessionFee"
          min="0"
          max="1000"
          step="5"
          value={defaultFee}
          placeholder={`e.g. ${defaultFee}`}
          class="w-full border border-ink-green/16 rounded-[10px] px-4 py-2.5 text-heading font-semibold bg-white hover:border-primary/50 transition-colors focus:ring-2 focus:ring-primary focus:border-primary"
        />
        <p id="fee-hint" class="text-xs text-body mt-1">Typical range: ${defaultRange.low}–${defaultRange.high}</p>
      </div>

      <!-- GP bulk-billed? -->
      <fieldset>
        <legend class="block text-sm font-semibold text-body mb-2">
          Is your GP bulk-billed?
        </legend>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          <label class="cursor-pointer">
            <input type="radio" name="gpBilling" value="yes" checked class="peer sr-only" />
            <span class={optionCard}>Yes, no out-of-pocket cost for GP visits</span>
          </label>
          <label class="cursor-pointer">
            <input type="radio" name="gpBilling" value="no" class="peer sr-only" />
            <span class={optionCard}>No, I pay a gap fee (~$40)</span>
          </label>
        </div>
      </fieldset>
    </form>

    <!-- Receipt: updates live as the form changes -->
    <div class="md:sticky md:top-24 md:self-start">
      <div id="calc-receipt" class="bg-white border border-ink-green/12 rounded-[10px] p-5 sm:p-6">
        <p class="text-[11.5px] font-semibold uppercase tracking-[0.08em] text-meta-sage">Your estimate</p>

        <div class="mt-4 space-y-2.5">
          <div class={receiptRow}>
            <span class="text-body">Session fee</span>
            <span class={receiptLeader} aria-hidden="true"></span>
            <span class="font-medium text-heading tabular-nums" data-receipt-fees>{aud.format(defaultFee)}</span>
          </div>
          <div class={receiptRow}>
            <span class="text-body">Medicare pays back</span>
            <span class={receiptLeader} aria-hidden="true"></span>
            <span class="font-medium text-primary tabular-nums" data-receipt-rebate>&minus;{aud.format(ssrRebate)}</span>
          </div>
        </div>

        <div class="mt-4 border-t border-hairline pt-4">
          <div class="flex items-baseline justify-between gap-3" aria-live="polite" aria-atomic="true">
            <span class="text-[15px] font-semibold text-heading">You pay per session</span>
            <span class="font-display font-semibold text-[30px] sm:text-[34px] leading-none tracking-[-0.02em] text-heading tabular-nums" data-receipt-total>{aud.format(ssrPerSession)}</span>
          </div>
          <!-- REVIEW: AI-drafted claim — Easyclaim rebates can only be paid onto an eftpos debit card, not credit. -->
          <p class="mt-2 text-[13px] leading-snug text-meta-sage" data-receipt-card-note>
            Have {ssrFeeLabel} on your card on the day &mdash; you can pay with any card, but the rebate can only go back onto a debit card.
          </p>
        </div>

        <div class="mt-4 border-t border-hairline pt-4">
          <p class="text-[11.5px] font-semibold uppercase tracking-[0.08em] text-meta-sage">One-off to get started</p>
          <div class={`mt-2.5 ${receiptRow}`}>
            <span class="text-body" data-receipt-gp-label>GP visit (care plan)</span>
            <span class={receiptLeader} aria-hidden="true"></span>
            <span class="font-medium text-heading tabular-nums" data-receipt-gp>{aud.format(ssrGpCost)}</span>
          </div>
        </div>

        <p class="mt-3 text-[13px] leading-snug text-meta-sage" data-receipt-note>
          Medicare covers up to 10 sessions like this each calendar year.
        </p>
      </div>

      <p class="mt-3 text-xs text-body">
        These are estimates only. Medicare rebate amounts may have changed; check
        <a href="https://www.servicesaustralia.gov.au/medicare" class="underline hover:text-primary transition-colors" target="_blank" rel="noopener">Services Australia</a>
        for current rates. Last updated: {costsData.lastUpdated}.
      </p>
    </div>
  </div>
</div>

<script>
  import '../scripts/cost-calculator.ts';
</script>
