---
import { getCollection } from 'astro:content';

const practitioners = await getCollection('practitioners');
const comparable = practitioners
  .filter((p) => p.data.bubbleKey)
  .map((p) => ({
    key: p.data.bubbleKey,
    title: p.data.title,
    cost: p.data.cost,
    rebate: p.data.rebate,
    referralRequired: p.data.referralRequired,
    referralNote: p.data.referralNote ?? null,
    bestFor: p.data.bestFor ?? null,
    registrationStatus: p.data.registrationStatus ?? null,
    waitTime: p.data.waitTime ?? null,
  }));
---
<div class="practitioner-compare" id="practitioner-compare">
  <p class="pc-prompt" id="pc-prompt">
    Curious how they stack up? Add two or three to compare them side by side.
  </p>
  <div class="pc-table" id="pc-table" hidden></div>
  <script is:inline type="application/json" id="pc-data" set:html={JSON.stringify(comparable)} />
</div>

<script>
  import '../scripts/practitioner-compare.ts';
</script>

<style is:global>
  .practitioner-compare .pc-prompt {
    text-align: center;
    font-size: 14px;
    color: var(--color-body);
    margin: 0;
  }

  .practitioner-compare .pc-grid {
    display: grid;
    grid-template-columns: 130px repeat(var(--pc-cols, 2), 1fr);
    gap: 8px;
    align-items: stretch;
  }

  .practitioner-compare .pc-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 8px;
    background: var(--color-bg-light);
    border-radius: 10px;
    padding: 12px 12px 10px;
  }

  .practitioner-compare .pc-head-name {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 14px;
    color: var(--color-heading);
    line-height: 1.3;
  }

  .practitioner-compare .pc-head-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex: 0 0 auto;
  }

  .practitioner-compare .pc-remove {
    background: none;
    border: none;
    padding: 2px 4px;
    font-size: 18px;
    line-height: 1;
    color: var(--color-body);
    cursor: pointer;
    transition: color 0.15s ease;
  }

  .practitioner-compare .pc-remove:hover {
    color: var(--color-heading);
  }

  .practitioner-compare .pc-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    font-weight: 600;
    color: var(--color-body);
    align-self: center;
    padding: 8px 0;
  }

  .practitioner-compare .pc-cell {
    background: var(--color-bg-light);
    border-radius: 10px;
    padding: 10px 12px;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-heading);
    line-height: 1.45;
  }

  .practitioner-compare .pc-cell-note {
    display: block;
    margin-top: 3px;
    font-size: 12px;
    font-weight: 400;
    color: var(--color-body);
  }

  .practitioner-compare .pc-cell .badge-pill {
    font-weight: 600;
  }

  /* Mobile: drop the label column; labels span the full row above their cells */
  @media (max-width: 767px) {
    .practitioner-compare .pc-grid {
      grid-template-columns: repeat(var(--pc-cols, 2), 1fr);
      gap: 6px;
    }

    .practitioner-compare .pc-label,
    .practitioner-compare .pc-corner {
      grid-column: 1 / -1;
      padding: 10px 0 0;
    }

    .practitioner-compare .pc-corner {
      display: none;
    }

    .practitioner-compare .pc-cell {
      font-size: 13px;
      padding: 9px 10px;
    }

    .practitioner-compare .pc-head-name {
      font-size: 13px;
    }
  }
</style>
