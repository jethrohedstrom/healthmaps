---
import StepByStep from './StepByStep.astro';
import type { PathwayCard } from '../data/pathway-cards';

interface Props extends PathwayCard {}

const { id, title, tagline, accentColor, badge, oneLiner, isCrisis, facts, steps } = Astro.props;

const bgClass = isCrisis ? 'bg-primary-light' : 'bg-white';

/* Tailwind safelist — accent border classes used via dynamic interpolation:
   border-l-accent-amber border-l-primary border-l-accent-blue
   border-l-accent-teal border-l-accent-purple border-l-accent-olive */
---

<details id={id} class={`pathway-card rounded-xl shadow-sm border-l-4 ${accentColor} ${bgClass}`}>
  <summary class="min-h-[48px] p-5 md:p-6 cursor-pointer select-none">
    {badge && (
      <span class="inline-block text-xs font-semibold text-white bg-primary px-3 py-1 rounded-full mb-2">{badge}</span>
    )}
    <span class="text-lg font-bold text-heading leading-snug block">{title}</span>
    <span class="text-sm text-body mt-1 block">{tagline}</span>
  </summary>

  <div class="px-5 md:px-6 pb-6">
    {/* One-liner */}
    <p class="text-lg leading-relaxed text-body mb-5">{oneLiner}</p>

    {/* Key facts */}
    <div class="flex flex-wrap gap-x-6 gap-y-3 mb-6 text-sm">
      <div>
        <span class="text-body">Cost:</span>{' '}
        <span class="font-semibold text-heading">{facts.cost}</span>
      </div>
      {facts.sessions && (
        <div>
          <span class="text-body">Sessions:</span>{' '}
          <span class="font-semibold text-heading">{facts.sessions}</span>
        </div>
      )}
      {facts.wait && (
        <div>
          <span class="text-body">Wait:</span>{' '}
          <span class="font-semibold text-heading">{facts.wait}</span>
        </div>
      )}
    </div>

    {/* Steps */}
    <StepByStep steps={steps} />
  </div>
</details>
