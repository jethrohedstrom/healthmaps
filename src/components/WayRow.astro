---
/**
 * One expandable pathway card in the "All the ways" list.
 *
 * Collapsed it reads as the original 6a row (icon tile + kicker + title +
 * one-line body); the whole row is the <summary> of a progressive-disclosure
 * <details>, which expands in place to the full pathway detail (facts,
 * timeline, best-for, step-by-step accordions with progress bar).
 *
 * `featured` gets the primary-light wrapper + solid green icon tile (GP row).
 * Icons reference the paint-* wobble filters defined once in pathway.astro.
 *
 * Behaviour hooks (pathway-progressive-steps.ts binds to these — keep them):
 * id, data-pathway-card, data-progressive-card, data-legacy-step-hash,
 * .pathway-details-toggle(--nested), .pathway-l1-body, [data-step-reveal],
 * li[data-step-index] with id `${id}-step-N`, and the data-progress* hooks.
 */
import PathwayTimeHorizon from './PathwayTimeHorizon.astro';
import { wayIconSvg, type WayIcon } from './way-icons';
import type { PathwayCard } from '../data/pathway-cards';

export type { WayIcon };

export interface Props {
  title: string;
  body: string;
  icon: WayIcon;
  kicker?: string;
  featured?: boolean;
  card: PathwayCard;
}

const { title, body, icon, kicker, featured = false, card } = Astro.props;
const { id, bestFor, oneLiner, facts, steps, timeHorizon, progressive, legacyStepHash } = card;

const tileClass = featured ? 'bg-primary text-white' : 'bg-primary-light text-primary';
const titleClass = featured ? 'text-[21px] md:text-[25px] text-wash-heading' : 'text-[20px] md:text-[24px] text-heading';
const bodyClass = featured ? 'text-wash-body' : 'text-body';
// Summary carries the row padding so it covers the whole card; the featured
// row keeps its slightly tighter horizontal padding from the 6a design.
const summaryPad = featured ? 'p-5 md:p-[26px]' : 'px-5 py-5 md:px-8 md:py-[26px]';
---

<!-- `contents` makes the wrapper layout-inert for plain rows, so featured
     and plain share one card body and only the wrapper styling differs. -->
<div class={featured ? 'bg-primary-light rounded-[18px] p-1.5' : 'contents'}>
  <div
    id={id}
    data-pathway-card
    data-progressive-card={progressive ? '' : undefined}
    data-legacy-step-hash={legacyStepHash ? '' : undefined}
    class="pathway-row-card scroll-mt-24 rounded-[14px] border border-transparent transition-colors duration-150 has-[>details[open]]:bg-white has-[>details[open]]:border-ink-green/10"
  >
    <details class="pathway-details-toggle">
      <summary class={`pathway-row-summary flex items-center gap-4 md:gap-[22px] rounded-[14px] cursor-pointer select-none ${summaryPad} ${featured ? '' : 'hover:bg-row-hover transition-colors duration-150'}`}>
        <span class={`inline-flex items-center justify-center w-12 h-12 md:w-[60px] md:h-[60px] rounded-[14px] md:rounded-[17px] shrink-0 ${tileClass}`} aria-hidden="true">
          <Fragment set:html={wayIconSvg[icon]} />
        </span>
        <span class="flex-1 min-w-0">
          {kicker && <span class="block text-[11.5px] font-semibold uppercase tracking-[0.08em] text-primary mb-[5px]">{kicker}</span>}
          <h3 class={`font-display font-semibold tracking-[-0.01em] leading-snug ${titleClass}`}>{title}</h3>
          <span class={`block text-base md:text-[17px] leading-[1.5] mt-1.5 ${bodyClass}`}>{body}</span>
          <span class="sr-only">, show details</span>
        </span>
        <span class="pathway-row-chevron shrink-0 text-primary" aria-hidden="true">
          <svg class="w-5 h-5 sm:w-6 sm:h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"></path></svg>
        </span>
      </summary>

      <div class={`pathway-l1-body px-5 pb-6 md:pb-8 ${featured ? 'md:px-[26px] md:pl-[108px]' : 'md:px-8 md:pl-[114px]'}`}>
        <p class="text-base md:text-[17px] leading-[1.5] text-body mb-5">{oneLiner}</p>
        <dl class="pathway-facts text-sm border-y border-ink-green/12 divide-y divide-ink-green/12 mb-4">
          <div class="flex justify-between gap-4 py-2.5">
            <dt class="text-meta-sage">Cost</dt>
            <dd class="font-semibold text-heading text-right">{facts.cost}</dd>
          </div>
          <div class="flex justify-between gap-4 py-2.5">
            <dt class="text-meta-sage">Sessions</dt>
            <dd class="font-semibold text-heading text-right">{facts.sessions ?? 'Varies'}</dd>
          </div>
        </dl>
        <div class="mb-5">
          <PathwayTimeHorizon events={timeHorizon?.events} />
        </div>
        <p class="text-sm text-meta-sage mb-6">{bestFor}</p>
        <details class="pathway-details-toggle pathway-details-toggle--nested">
          <summary class="inline-flex items-center text-sm font-semibold text-primary cursor-pointer select-none hover:text-primary-dark transition-colors duration-150">
            <span class="sr-only">{title}: </span>
            <span class="pathway-label-show">How does this work?</span>
            <span class="pathway-label-hide">Hide steps</span>
          </summary>
          <ol class="pathway-step-accordions mt-4" data-step-reveal data-step-total={steps.length}>
            {steps.map((step, idx) => (
              <li id={`${id}-step-${step.number}`} class="scroll-mt-24" data-step-index={step.number} hidden={idx > 0}>
                <details class="pathway-step-item">
                  <summary class="pathway-step-summary">
                    <span class="pathway-step-number" aria-hidden="true">{step.number}</span>
                    <span class="pathway-step-title">{step.title}</span>
                  </summary>
                  <div class="pathway-step-detail prose" set:html={step.detail} />
                </details>
              </li>
            ))}
          </ol>
          <div class="pathway-gp-progress mt-5 pt-4 border-t border-ink-green/12">
            <p class="text-xs text-meta-sage mb-2" id={`${id}-progress-label`} data-progress-label>
              Step 1 of {steps.length}
            </p>
            <div
              class="pathway-gp-progress-track h-1.5 rounded-full bg-primary-light overflow-hidden"
              role="progressbar"
              aria-valuemin="1"
              aria-valuemax={steps.length}
              aria-valuenow="1"
              aria-labelledby={`${id}-progress-label`}
              data-progressbar
            >
              <div
                class="pathway-gp-progress-fill h-full bg-primary pathway-gp-progress-fill-motion"
                style={`width: ${(100 / steps.length).toFixed(4)}%`}
                data-progress-fill
              />
            </div>
            <p class="sr-only" aria-live="polite" aria-atomic="true" data-progress-live></p>
          </div>
        </details>
      </div>
    </details>
  </div>
</div>

<script>
  import '../scripts/pathway-progressive-steps.ts';
</script>
