---
// Persistent crisis bar — fixed to bottom of viewport on the pathway page.
// Coexists with the floating CrisisBanner pill (z-50); this bar sits at z-40.
---

<div
  role="complementary"
  aria-label="Crisis support"
  class="fixed bottom-0 left-0 right-0 z-40 bg-dark text-white shadow-lg"
>
  <div class="max-w-[720px] mx-auto px-4 py-3 flex items-center justify-between">
    <a
      href="tel:131114"
      class="flex items-center gap-2 text-sm font-semibold min-h-[48px] px-2 rounded-lg hover:bg-white/15 transition-colors"
    >
      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
      </svg>
      <span>Lifeline <strong>13 11 14</strong></span>
    </a>

    <a
      href="tel:000"
      class="flex items-center gap-2 text-sm font-semibold min-h-[48px] px-2 rounded-lg hover:bg-white/15 transition-colors"
    >
      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
      </svg>
      <span>Emergency <strong>000</strong></span>
    </a>
  </div>
</div>
