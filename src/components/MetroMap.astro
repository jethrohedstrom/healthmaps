---
// MetroMap.astro — metro-style pathway diagram showing 5 routes to mental health support
---

<!-- Screen reader description -->
<div class="sr-only">
  <h3>Five routes to mental health support</h3>
  <p>Route 1 (most common): See your GP for a Mental Health Care Plan, which unlocks
  Medicare rebates for a Psychologist ($50–$220/session) or Social worker or OT
  ($50–$160/session).</p>
  <p>Route 2: Ask the same GP for a separate specialist referral to a Psychiatrist
  (2–6 month wait). This referral is written on a different piece of paper from the
  Mental Health Care Plan.</p>
  <p>Route 3 — Go private: Find a practitioner and start sessions directly. Options
  include Psychologist, Counsellor, Psychotherapist, or Social worker. Cost is
  $120–$330+ per session with no referral needed and no Medicare rebate.</p>
  <p>Route 4 — Low-cost services: Find a service, attend an assessment or intake, and
  start sessions. Options include Medicare Mental Health Centre, community health
  services, headspace, and university clinics. Free or low-cost (sliding scale), with
  no referral needed for most services.</p>
  <p>Route 5 (crisis): If you need help now, use a free 24/7 crisis service.
  Emergency 000, Lifeline 13 11 14, or Beyond Blue 1300 22 4636.</p>
</div>

<div class="metro-map-root">

  <!-- Reset control — shown only when a route is selected -->
  <div class="metro-reset-wrap">
    <button type="button" class="metro-reset" aria-label="Clear selection and show all routes" hidden>
      <span aria-hidden="true">×</span> Show all routes
    </button>
  </div>

<!-- ============ DESKTOP SVG (md+) ============ -->
<!--
  Grid system:
    • Rails at y = 100 (GP), 200 (Psych), 300 (Direct / "You"), 400 (Low-cost), 500 (Crisis)
    • Station columns at x = 200, 400, 600; terminus at x = 760
    • All routes terminate at x = 760 so lines read as equal-length tracks
    • Lines are drawn as single continuous paths; stations are outer-filled circles
      with a white inner dot that sits ON the line (no gaps in the track)
-->
<div class="hidden md:block">
  <svg
    class="metro-map-svg w-full h-auto"
    viewBox="0 0 960 580"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-label="Metro-style diagram of five pathways to mental health support: the GP / Medicare route unlocking rebated psychology or social worker / OT sessions; a separate specialist referral from the GP to a psychiatrist; a direct private route with no referral; a low-cost community route via Medicare Mental Health Centres, headspace, and university clinics; and a crisis route via 000, Lifeline, and Beyond Blue."
  >
    <!-- "You" start node (shared, outside any route group) -->
    <circle cx="55" cy="300" r="22" fill="var(--color-primary-light)" stroke="var(--color-primary)" stroke-width="3" />
    <text x="55" y="305" text-anchor="middle" class="metro-heading" font-size="15">You</text>

    <!-- Instructional helper text near "You" — fades out once a route is selected -->
    <text x="18" y="350" text-anchor="start" class="metro-instruction" font-size="11">
      Select a route to explore
    </text>

    <!-- ── GP Route (green, y=100) — branches to Psychologist & Social worker/OT at terminus ── -->
    <g class="route-group" data-route="gp" tabindex="0" aria-keyshortcuts="Enter Space"
       aria-label="GP and Medicare route — most common pathway">

      <!-- Hit-targets -->
      <path d="M 75,300 C 140,300 160,100 200,100 L 720,100" class="route-hit" />
      <path d="M 720,100 L 760,85" class="route-hit" />
      <path d="M 720,100 L 760,115" class="route-hit" />

      <!-- Continuous line: fork from "You" → GP rail → up to terminus fan-out point -->
      <path d="M 75,300 C 140,300 160,100 200,100 L 720,100"
            stroke="var(--color-primary)" stroke-width="3" fill="none" stroke-linecap="round" />

      <!-- Terminus fan-out: two short branches to practitioner endpoints -->
      <path d="M 720,100 L 760,85"
            stroke="var(--color-primary)" stroke-width="3" fill="none" stroke-linecap="round" />
      <path d="M 720,100 L 760,115"
            stroke="var(--color-primary)" stroke-width="3" fill="none" stroke-linecap="round" />

      <!-- "Most common route" pill -->
      <rect x="300" y="63" width="150" height="22" rx="11" fill="var(--color-primary)" />
      <text x="375" y="78" text-anchor="middle" fill="white" font-size="11" font-weight="600"
            font-family="var(--font-sans)">Most common route</text>

      <!-- Station: See your GP -->
      <circle cx="200" cy="100" r="7" fill="var(--color-primary)" />
      <circle cx="200" cy="100" r="3" fill="white" />
      <text x="200" y="130" text-anchor="middle" class="metro-heading route-detail" font-size="13">See your GP</text>

      <!-- Station: Mental health care plan -->
      <circle cx="400" cy="100" r="7" fill="var(--color-primary)" />
      <circle cx="400" cy="100" r="3" fill="white" />
      <g class="route-detail">
        <text x="400" y="130" text-anchor="middle" font-size="13" font-weight="700"
              font-family="var(--font-display)" fill="var(--color-heading)">Mental health care plan</text>
        <rect x="328" y="141" width="144" height="20" rx="10" fill="var(--color-primary-light)" />
        <text x="400" y="155" text-anchor="middle" font-size="10" fill="var(--color-primary)" font-weight="600"
              font-family="var(--font-sans)">Unlocks Medicare rebates</text>
      </g>

      <!-- Terminus endpoint dots (practitioner fan-out) -->
      <circle cx="760" cy="85" r="6" fill="var(--color-primary)" />
      <circle cx="760" cy="85" r="2.5" fill="white" />
      <circle cx="760" cy="115" r="6" fill="var(--color-primary)" />
      <circle cx="760" cy="115" r="2.5" fill="white" />

      <!-- Endpoint labels -->
      <text x="775" y="82" class="metro-heading" font-size="13">Psychologist</text>
      <text x="775" y="97" class="route-detail" font-size="11" fill="var(--color-body)"
            font-family="var(--font-sans)">$50–$220/session</text>
      <text x="775" y="112" class="metro-heading" font-size="13">Social worker, OT</text>
      <text x="775" y="127" class="route-detail" font-size="11" fill="var(--color-body)"
            font-family="var(--font-sans)">$50–$160/session</text>
    </g>

    <!-- ── Psychiatrist Route (purple, y=200) — separate specialist referral, branches from GP station ── -->
    <g class="route-group" data-route="psychiatrist" tabindex="0" aria-keyshortcuts="Enter Space"
       aria-label="Psychiatrist route — separate specialist referral from your GP">

      <path d="M 200,107 C 240,200 280,200 320,200 L 760,200" class="route-hit" />

      <path d="M 200,107 C 240,200 280,200 320,200 L 760,200"
            stroke="var(--color-accent-purple)" stroke-width="3" fill="none" stroke-linecap="round" />

      <!-- "Also from your GP" pill -->
      <rect x="300" y="163" width="150" height="22" rx="11" fill="var(--color-accent-purple-light)" />
      <text x="375" y="178" text-anchor="middle" font-size="11" font-weight="600"
            fill="var(--color-accent-purple)" font-family="var(--font-sans)">Also from your GP</text>

      <!-- Terminus station -->
      <circle cx="760" cy="200" r="7" fill="var(--color-accent-purple)" />
      <circle cx="760" cy="200" r="3" fill="white" />

      <!-- Endpoint labels -->
      <text x="775" y="197" font-size="13" font-weight="700"
            font-family="var(--font-display)" fill="var(--color-accent-purple)">Psychiatrist</text>
      <text x="775" y="213" class="route-detail" font-size="11" fill="var(--color-body)"
            font-family="var(--font-sans)">2–6 month wait</text>
    </g>

    <!-- ── Direct Route (blue, y=300) — "You" rail runs straight right ── -->
    <g class="route-group" data-route="direct" tabindex="0" aria-keyshortcuts="Enter Space"
       aria-label="Direct private route — no referral needed, full price">

      <path d="M 77,300 L 760,300" class="route-hit" />

      <path d="M 77,300 L 760,300"
            stroke="var(--color-accent-blue)" stroke-width="3" fill="none" stroke-linecap="round" />

      <!-- "Less common route" pill (outlined) -->
      <rect x="300" y="263" width="150" height="22" rx="11" fill="white"
            stroke="var(--color-accent-blue)" stroke-width="1.5" />
      <text x="375" y="278" text-anchor="middle" font-size="11" font-weight="600"
            fill="var(--color-accent-blue)" font-family="var(--font-sans)">Less common route</text>

      <!-- Station: Find a practitioner -->
      <circle cx="200" cy="300" r="7" fill="var(--color-accent-blue)" />
      <circle cx="200" cy="300" r="3" fill="white" />
      <text x="200" y="330" text-anchor="middle" class="metro-heading route-detail" font-size="13">Find a practitioner</text>

      <!-- Station: Start sessions -->
      <circle cx="400" cy="300" r="7" fill="var(--color-accent-blue)" />
      <circle cx="400" cy="300" r="3" fill="white" />
      <text x="400" y="330" text-anchor="middle" class="metro-heading route-detail" font-size="13">Start sessions</text>

      <!-- Terminus -->
      <circle cx="760" cy="300" r="7" fill="var(--color-accent-blue)" />
      <circle cx="760" cy="300" r="3" fill="white" />

      <!-- Endpoint label (visible default; hides on select so detail block can take its place) -->
      <text x="775" y="297" class="metro-heading route-endpoint-label" font-size="13"
            fill="var(--color-accent-blue)">Go private</text>

      <!-- Detail block (visible on select) -->
      <text x="775" y="297" class="route-detail" font-size="13" font-weight="700"
            font-family="var(--font-display)" fill="var(--color-accent-blue)">Go private</text>
      <text x="775" y="314" class="route-detail" font-size="11" fill="var(--color-body)"
            font-family="var(--font-sans)">
        <tspan x="775" dy="0">Psychologist, counsellor,</tspan>
        <tspan x="775" dy="14">psychotherapist, social worker</tspan>
      </text>
      <text x="775" y="348" class="route-detail" font-size="11"
            font-family="var(--font-sans)">
        <tspan font-weight="700" fill="var(--color-heading)">$120–$330+/session</tspan>
      </text>
      <text x="775" y="363" class="route-detail" font-size="11" fill="var(--color-body)"
            font-family="var(--font-sans)">No referral · no rebate</text>
    </g>

    <!-- ── Low-cost / Community Route (amber, y=400) ── -->
    <g class="route-group" data-route="low-cost" tabindex="0" aria-keyshortcuts="Enter Space"
       aria-label="Low-cost and community route — free or sliding-scale, no referral needed for most">

      <path d="M 75,300 C 140,300 160,400 200,400 L 760,400" class="route-hit" />

      <path d="M 75,300 C 140,300 160,400 200,400 L 760,400"
            stroke="var(--color-accent-amber)" stroke-width="3" fill="none" stroke-linecap="round" />

      <!-- "No referral needed" pill -->
      <rect x="300" y="370" width="150" height="22" rx="11" fill="var(--color-accent-amber-light)" />
      <text x="375" y="385" text-anchor="middle" font-size="11" font-weight="600"
            fill="var(--color-accent-amber)" font-family="var(--font-sans)">No referral needed</text>

      <!-- Stations -->
      <circle cx="200" cy="400" r="7" fill="var(--color-accent-amber)" />
      <circle cx="200" cy="400" r="3" fill="white" />
      <text x="200" y="430" text-anchor="middle" class="metro-heading route-detail" font-size="13">Find a service</text>

      <circle cx="400" cy="400" r="7" fill="var(--color-accent-amber)" />
      <circle cx="400" cy="400" r="3" fill="white" />
      <text x="400" y="430" text-anchor="middle" class="metro-heading route-detail" font-size="13">Assessment</text>

      <circle cx="600" cy="400" r="7" fill="var(--color-accent-amber)" />
      <circle cx="600" cy="400" r="3" fill="white" />
      <text x="600" y="430" text-anchor="middle" class="metro-heading route-detail" font-size="13">Start sessions</text>

      <!-- Terminus -->
      <circle cx="760" cy="400" r="7" fill="var(--color-accent-amber)" />
      <circle cx="760" cy="400" r="3" fill="white" />

      <!-- Endpoint label (visible default) -->
      <text x="775" y="397" class="metro-heading route-endpoint-label" font-size="13"
            fill="var(--color-accent-amber)">Low-cost services</text>

      <!-- Detail block (visible on select) -->
      <text x="775" y="397" class="route-detail" font-size="13" font-weight="700"
            font-family="var(--font-display)" fill="var(--color-accent-amber)">Low-cost services</text>
      <text x="775" y="414" class="route-detail" font-size="11" fill="var(--color-body)"
            font-family="var(--font-sans)">
        <tspan x="775" dy="0">Medicare MH Centre, community,</tspan>
        <tspan x="775" dy="14">headspace, university clinics</tspan>
      </text>
      <text x="775" y="448" class="route-detail" font-size="11"
            font-family="var(--font-sans)">
        <tspan font-weight="700" fill="var(--color-heading)">Free or sliding-scale</tspan>
      </text>
    </g>

    <!-- ── Crisis Route (red, y=500) ── -->
    <g class="route-group" data-route="crisis" tabindex="0" aria-keyshortcuts="Enter Space"
       aria-label="Crisis route — free, 24/7 immediate help">

      <path d="M 75,300 C 160,300 170,500 200,500 L 760,500" class="route-hit" />

      <path d="M 75,300 C 160,300 170,500 200,500 L 760,500"
            stroke="var(--color-accent-red)" stroke-width="3" fill="none" stroke-linecap="round" />

      <!-- "Immediate, free" pill -->
      <rect x="300" y="470" width="150" height="22" rx="11" fill="var(--color-accent-red-light)" />
      <text x="375" y="485" text-anchor="middle" font-size="11" font-weight="600"
            fill="var(--color-accent-red)" font-family="var(--font-sans)">Immediate, free</text>

      <!-- Action station -->
      <circle cx="200" cy="500" r="7" fill="var(--color-accent-red)" />
      <circle cx="200" cy="500" r="3" fill="white" />
      <text x="200" y="530" text-anchor="middle" font-size="13" font-weight="700"
            font-family="var(--font-display)" fill="var(--color-accent-red)">I need help now</text>

      <!-- Terminus -->
      <circle cx="760" cy="500" r="7" fill="var(--color-accent-red)" />
      <circle cx="760" cy="500" r="3" fill="white" />

      <!-- Crisis numbers (always visible — must stay tappable regardless of selection) -->
      <text x="775" y="492" font-size="11" fill="var(--color-body)"
            font-family="var(--font-sans)">
        <tspan x="775" dy="0"><tspan font-weight="700" fill="var(--color-heading)">Emergency</tspan> <a href="tel:000">000</a></tspan>
        <tspan x="775" dy="14"><tspan font-weight="700" fill="var(--color-heading)">Lifeline</tspan> <a href="tel:131114">13 11 14</a></tspan>
        <tspan x="775" dy="14"><tspan font-weight="700" fill="var(--color-heading)">Beyond Blue</tspan> <a href="tel:1300224636">1300 22 4636</a></tspan>
        <tspan x="775" dy="16" font-style="italic">Free, 24/7</tspan>
      </text>
    </g>
  </svg>
</div>

<!-- ============ MOBILE VERTICAL LAYOUT (<md) ============ -->
<div class="md:hidden">
  <!-- You starting point -->
  <div class="flex items-center gap-3 mb-4">
    <div class="w-11 h-11 rounded-full bg-primary-light border-[3px] border-primary flex items-center justify-center shrink-0">
      <span class="text-sm font-bold text-primary" style="font-family: var(--font-display)">You</span>
    </div>
    <p class="text-body text-sm">Five routes to mental health support</p>
  </div>
  <p class="metro-instruction text-xs italic mb-6" style="color: var(--color-body)">Select a route to explore</p>

  <!-- ── GP Route ── -->
  <div class="mb-10 route-group" data-route="gp" tabindex="0" aria-keyshortcuts="Enter Space"
       aria-label="GP and Medicare route — most common pathway">
    <div class="mb-4">
      <span class="inline-block text-xs font-semibold bg-primary text-white px-3 py-1 rounded-full">Most common route</span>
    </div>

    <!-- Station: See your GP -->
    <div class="flex gap-4 route-detail">
      <div class="flex flex-col items-center">
        <div class="w-4 h-4 rounded-full bg-primary-light border-[2.5px] border-primary shrink-0 mt-0.5"></div>
        <div class="w-[3px] flex-1 bg-primary rounded-full my-1"></div>
      </div>
      <div class="pb-5">
        <span class="font-semibold text-heading text-[15px]" style="font-family: var(--font-display)">See your GP</span>
      </div>
    </div>

    <!-- Station: Mental health care plan -->
    <div class="flex gap-4 route-detail">
      <div class="flex flex-col items-center">
        <div class="w-4 h-4 rounded-full bg-primary-light border-[2.5px] border-primary shrink-0 mt-0.5"></div>
        <div class="w-[3px] flex-1 bg-primary rounded-full my-1"></div>
      </div>
      <div class="pb-5">
        <span class="font-semibold text-heading text-[15px]" style="font-family: var(--font-display)">Mental health care plan</span>
        <span class="route-detail block text-sm text-body mt-1">🔓 Unlocks Medicare rebates</span>
      </div>
    </div>

    <!-- Fan-out: Practitioner endpoints -->
    <div class="ml-2 space-y-3">
      <div class="flex items-start gap-3">
        <div class="w-3 h-3 mt-1.5 rounded-full bg-primary-light border-2 border-primary shrink-0"></div>
        <div>
          <span class="text-sm font-semibold text-heading">Psychologist</span>
          <span class="route-detail text-sm text-body block">$50–$220/session</span>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <div class="w-3 h-3 mt-1.5 rounded-full bg-primary-light border-2 border-primary shrink-0"></div>
        <div>
          <span class="text-sm font-semibold text-heading">Social worker, OT</span>
          <span class="route-detail text-sm text-body block">$50–$160/session</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Specialist referral (Psychiatrist) route ── -->
  <div class="mb-10 route-group" data-route="psychiatrist" tabindex="0" aria-keyshortcuts="Enter Space"
       aria-label="Psychiatrist route — separate specialist referral from your GP">
    <div class="mb-4 route-detail">
      <span class="inline-block text-xs font-semibold px-3 py-1 rounded-full"
            style="background: var(--color-accent-purple-light); color: var(--color-accent-purple)">Also from your GP</span>
    </div>
    <p class="route-detail text-sm text-body mb-4">A separate referral — written on a different piece of paper from the Mental Health Care Plan.</p>

    <div class="flex gap-4">
      <div class="flex flex-col items-center">
        <div class="w-4 h-4 rounded-full shrink-0 mt-0.5"
             style="background: var(--color-accent-purple-light); border: 2.5px solid var(--color-accent-purple)"></div>
      </div>
      <div>
        <span class="font-semibold text-[15px]" style="color: var(--color-accent-purple)">Psychiatrist</span>
        <span class="route-detail block text-sm text-body mt-1">Specialist referral — 2–6 month wait</span>
      </div>
    </div>
  </div>

  <!-- ── Direct Route ── -->
  <div class="mb-10 route-group" data-route="direct" tabindex="0" aria-keyshortcuts="Enter Space"
       aria-label="Direct private route — no referral needed, full price">
    <div class="mb-4 route-detail">
      <span class="inline-block text-xs font-semibold border border-accent-blue text-accent-blue px-3 py-1 rounded-full">Less common route</span>
    </div>

    <!-- Station: Find a practitioner -->
    <div class="flex gap-4 route-detail">
      <div class="flex flex-col items-center">
        <div class="w-3.5 h-3.5 rounded-full bg-accent-blue-light border-2 border-accent-blue shrink-0 mt-0.5"></div>
        <div class="w-[2px] flex-1 bg-accent-blue/50 rounded-full my-1"></div>
      </div>
      <div class="pb-5">
        <span class="font-semibold text-heading text-[15px]" style="font-family: var(--font-display)">Find a practitioner</span>
      </div>
    </div>

    <!-- Station: Start sessions -->
    <div class="flex gap-4 route-detail">
      <div class="flex flex-col items-center">
        <div class="w-3.5 h-3.5 rounded-full bg-accent-blue-light border-2 border-accent-blue shrink-0 mt-0.5"></div>
      </div>
      <div>
        <span class="font-semibold text-heading text-[15px]" style="font-family: var(--font-display)">Start sessions</span>
      </div>
    </div>

    <!-- Info -->
    <div class="route-detail ml-7 mt-3 text-sm text-body space-y-1">
      <p>Psychologist, counsellor, psychotherapist, social worker</p>
      <p class="mt-3 font-medium text-heading">$120–$330+/session</p>
      <p>No referral needed</p>
      <p>No Medicare rebate — full price</p>
    </div>

    <!-- Always-visible destination label (gives the collapsed route an identity + tap target in default state) -->
    <div class="flex items-center gap-3">
      <div class="w-3 h-3 rounded-full bg-accent-blue-light border-2 border-accent-blue shrink-0"></div>
      <span class="text-sm font-semibold" style="color: var(--color-accent-blue)">Go private</span>
    </div>
  </div>

  <!-- ── Low-cost / Community Route ── -->
  <div class="mb-10 route-group" data-route="low-cost" tabindex="0" aria-keyshortcuts="Enter Space"
       aria-label="Low-cost and community route — free or sliding-scale, no referral needed for most">
    <div class="mb-4 route-detail">
      <span class="inline-block text-xs font-semibold bg-accent-amber-light text-accent-amber px-3 py-1 rounded-full">No referral needed</span>
    </div>

    <!-- Station: Find a service -->
    <div class="flex gap-4 route-detail">
      <div class="flex flex-col items-center">
        <div class="w-3.5 h-3.5 rounded-full bg-accent-amber-light border-2 border-accent-amber shrink-0 mt-0.5"></div>
        <div class="w-[2px] flex-1 bg-accent-amber/50 rounded-full my-1"></div>
      </div>
      <div class="pb-5">
        <span class="font-semibold text-heading text-[15px]" style="font-family: var(--font-display)">Find a service</span>
      </div>
    </div>

    <!-- Station: Assessment / intake -->
    <div class="flex gap-4 route-detail">
      <div class="flex flex-col items-center">
        <div class="w-3.5 h-3.5 rounded-full bg-accent-amber-light border-2 border-accent-amber shrink-0 mt-0.5"></div>
        <div class="w-[2px] flex-1 bg-accent-amber/50 rounded-full my-1"></div>
      </div>
      <div class="pb-5">
        <span class="font-semibold text-heading text-[15px]" style="font-family: var(--font-display)">Assessment</span>
      </div>
    </div>

    <!-- Station: Start sessions -->
    <div class="flex gap-4 route-detail">
      <div class="flex flex-col items-center">
        <div class="w-3.5 h-3.5 rounded-full bg-accent-amber-light border-2 border-accent-amber shrink-0 mt-0.5"></div>
      </div>
      <div>
        <span class="font-semibold text-heading text-[15px]" style="font-family: var(--font-display)">Start sessions</span>
      </div>
    </div>

    <!-- Info -->
    <div class="route-detail ml-7 mt-3 text-sm text-body space-y-1">
      <p>Medicare Mental Health Centre, community health, headspace, university clinics</p>
      <p class="mt-3 font-medium text-heading">Free or low-cost (sliding scale)</p>
      <p>No referral needed for most</p>
    </div>

    <!-- Always-visible destination label (gives the collapsed route an identity + tap target in default state) -->
