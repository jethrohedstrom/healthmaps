---
interface Props {
  step: number;
  title: string;
  summary: string;
  isLast?: boolean;
  open?: boolean;
}

const { step, title, summary, isLast = false, open = false } = Astro.props;
---
<div class="pathway-step relative pl-14 md:pl-16 pb-10 scroll-mt-24" id={`step-${step}`}>
  <!-- Step connector line -->
  {!isLast && (
    <div class="step-connector absolute left-[1.4375rem] top-12 bottom-0 w-px bg-border" aria-hidden="true"></div>
  )}

  <!-- Step number circle -->
  <div class="step-circle absolute left-0 top-0 w-12 h-12 rounded-full bg-white border-2 border-border text-body flex items-center justify-center font-bold text-sm transition-all duration-300 ease-out" aria-hidden="true">
    {step}
  </div>

  <details class="group" open={open}>
    <summary class="text-lg font-semibold text-heading hover:text-primary transition-colors py-1">
      {title}
    </summary>
    <p class="text-body text-sm mt-1 mb-3">{summary}</p>
    <div class="prose prose-sm max-w-none text-body mt-4 bg-white rounded-xl p-5 shadow-sm border-l-[3px] border-primary/40">
      <slot />
    </div>
  </details>
</div>
