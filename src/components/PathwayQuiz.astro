---
---

<!-- Flat split quiz card (design handoff 6a). Deliberately no box-shadow.
     The bottom rail sits outside the screens but inside [data-pathway-quiz],
     so it persists on every quiz screen and event delegation still reaches it. -->
<div data-pathway-quiz class="max-w-[640px] mx-auto text-left bg-paper-cream border border-ink-green/16 rounded-[14px] overflow-hidden">
  <p class="sr-only" aria-live="polite" aria-atomic="true" data-quiz-live></p>

  <div data-quiz-screen="intro" class="pathway-quiz-screen flex flex-col sm:flex-row sm:items-stretch">
    <div class="sm:flex-[1.3] pt-[30px] px-8 pb-[26px]">
      <h2 id="pathway-quiz-intro-title" tabindex="-1" data-quiz-heading class="font-display font-semibold text-[23px] tracking-[-0.012em] leading-snug text-heading">
        Not sure where to start?
      </h2>
      <p class="text-[15.5px] leading-[1.55] text-body mt-[9px]">
        Answer four quick questions and we&rsquo;ll suggest a good first step for your situation.
      </p>
    </div>
    <div class="shrink-0 h-px mx-8 bg-ink-green/12 sm:h-auto sm:w-px sm:mx-0 sm:my-[22px]"></div>
    <div class="sm:flex-1 py-[26px] px-8 flex flex-col justify-center gap-[13px]">
      <button type="button" data-quiz-start class="pathway-quiz-primary-button w-full min-h-11 rounded-[10px] bg-primary hover:bg-primary-dark transition-colors duration-150 px-5 py-[13px] text-center text-base font-semibold text-white">
        Start the quiz
      </button>
      <ul class="flex flex-col gap-[5px] text-[13px] text-meta-sage" role="list">
        <li class="flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-primary opacity-55 shrink-0" aria-hidden="true"></span>&#8776; 2 minutes</li>
        <li class="flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-primary opacity-55 shrink-0" aria-hidden="true"></span>No sign-up</li>
        <li class="flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-primary opacity-55 shrink-0" aria-hidden="true"></span>Stays in your browser</li>
      </ul>
    </div>
  </div>

  <div data-quiz-screen="question" data-question-index="0" class="pathway-quiz-screen pt-[30px] px-8 pb-8" hidden>
    <p class="text-sm font-semibold text-primary mb-3">Question 1 of 4</p>
    <h2 tabindex="-1" data-quiz-heading class="font-display font-semibold text-[23px] tracking-[-0.012em] leading-snug text-heading mb-4">
      What matters most to you right now?
    </h2>
    <div class="pathway-quiz-answer-list" role="group" aria-label="What matters most to you right now?">
      <button type="button" data-quiz-answer data-score-private="3" data-score-self-guided="1" data-answer-label="Getting seen as fast as possible" class="pathway-quiz-answer">
        Getting seen as fast as possible
      </button>
      <button type="button" data-quiz-answer data-score-low-cost="3" data-score-through-gp="1" data-score-self-guided="1" data-answer-label="Keeping the cost down" class="pathway-quiz-answer">
        Keeping the cost down
      </button>
      <button type="button" data-quiz-answer data-score-private="3" data-score-through-gp="1" data-answer-label="Finding the right kind of person" class="pathway-quiz-answer">
        Finding the right kind of person
      </button>
      <button type="button" data-quiz-answer data-score-through-gp="1" data-answer-label="I'm not sure yet" class="pathway-quiz-answer">
        I'm not sure yet
      </button>
    </div>
  </div>

  <div data-quiz-screen="question" data-question-index="1" class="pathway-quiz-screen pt-[30px] px-8 pb-8" hidden>
    <p class="text-sm font-semibold text-primary mb-3">Question 2 of 4</p>
    <h2 tabindex="-1" data-quiz-heading class="font-display font-semibold text-[23px] tracking-[-0.012em] leading-snug text-heading mb-4">
      When it comes to cost, what fits you best right now?
    </h2>
    <div class="pathway-quiz-answer-list" role="group" aria-label="When it comes to cost, what fits you best right now?">
      <button type="button" data-quiz-answer data-score-through-gp="3" data-answer-label="I'll go the regular route to keep costs down" class="pathway-quiz-answer">
        I'll go the regular route to keep costs down
      </button>
      <button type="button" data-quiz-answer data-score-private="3" data-answer-label="I'm not really concerned about cost" class="pathway-quiz-answer">
        I'm not really concerned about cost
      </button>
      <button type="button" data-quiz-answer data-score-low-cost="3" data-score-self-guided="1" data-answer-label="I need free or very low-cost options" class="pathway-quiz-answer">
        I need free or very low-cost options
      </button>
    </div>
  </div>

  <div data-quiz-screen="question" data-question-index="2" class="pathway-quiz-screen pt-[30px] px-8 pb-8" hidden>
    <p class="text-sm font-semibold text-primary mb-3">Question 3 of 4</p>
    <h2 tabindex="-1" data-quiz-heading class="font-display font-semibold text-[23px] tracking-[-0.012em] leading-snug text-heading mb-4">
      How would you prefer to start?
    </h2>
    <div class="pathway-quiz-answer-list" role="group" aria-label="How would you prefer to start?">
      <button type="button" data-quiz-answer data-score-through-gp="2" data-score-low-cost="1" data-answer-label="With a doctor who can point me in the right direction" class="pathway-quiz-answer">
        With a doctor who can point me in the right direction
      </button>
      <button type="button" data-quiz-answer data-score-private="2" data-score-through-gp="1" data-answer-label="Straight to a therapist" class="pathway-quiz-answer">
        Straight to a therapist
      </button>
      <button type="button" data-quiz-answer data-score-self-guided="3" data-answer-label="On my own, online, at my own pace" class="pathway-quiz-answer">
        On my own, online, at my own pace
      </button>
      <button type="button" data-quiz-answer data-score-low-cost="3" data-answer-label="Through free or community services" class="pathway-quiz-answer">
        Through free or community services
      </button>
    </div>
  </div>

  <div data-quiz-screen="question" data-question-index="3" class="pathway-quiz-screen pt-[30px] px-8 pb-8" hidden>
    <p class="text-sm font-semibold text-primary mb-3">Question 4 of 4</p>
    <h2 tabindex="-1" data-quiz-heading class="font-display font-semibold text-[23px] tracking-[-0.012em] leading-snug text-heading mb-4">
      Do you have a regular GP you can see?
    </h2>
    <div class="pathway-quiz-answer-list" role="group" aria-label="Do you have a regular GP you can see?">
      <button type="button" data-quiz-answer data-score-through-gp="3" data-answer-label="Yes" class="pathway-quiz-answer">
        Yes
      </button>
      <button type="button" data-quiz-answer data-score-through-gp="2" data-answer-label="I can get to one, but it may take a little time" class="pathway-quiz-answer">
        I can get to one, but it may take a little time
      </button>
      <button type="button" data-quiz-answer data-score-low-cost="1" data-score-private="1" data-score-self-guided="1" data-answer-label="No / not sure" class="pathway-quiz-answer">
        No / not sure
      </button>
    </div>
  </div>

  <div data-quiz-screen="result" class="pathway-quiz-screen pt-[30px] px-8 pb-8" hidden>
    <p class="text-sm font-semibold text-primary mb-3">Suggested starting point</p>
    <h2 tabindex="-1" data-quiz-heading data-result-title class="font-display font-semibold text-[23px] tracking-[-0.012em] leading-snug text-heading mb-4">
      Your result
    </h2>
    <p data-result-summary class="text-[15.5px] leading-[1.55] text-body mb-6"></p>
    <div class="rounded-[10px] border border-ink-green/12 p-4 mb-6">
      <p class="text-sm font-semibold text-heading mb-1">Another good option</p>
      <p data-runner-up class="text-[15.5px] leading-[1.55] text-body"></p>
    </div>
    <div class="flex flex-col sm:flex-row gap-3">
      <a href="#through-gp" data-result-link class="pathway-quiz-primary-button inline-flex min-h-11 items-center justify-center rounded-[10px] bg-primary hover:bg-primary-dark transition-colors duration-150 px-6 py-[13px] text-base font-semibold text-white">
        Go to this pathway
      </a>
      <button type="button" data-quiz-reset class="pathway-quiz-secondary-button min-h-11 rounded-[10px] border border-ink-green/16 bg-transparent hover:bg-row-hover transition-colors duration-150 px-6 py-[13px] text-base font-semibold text-heading">
        Start over
      </button>
    </div>
  </div>

  <div class="border-t border-ink-green/12 px-8 py-1 flex flex-wrap items-center justify-between gap-x-4">
    <a href="#all-the-ways" class="pathway-quiz-rail-link min-h-11 inline-flex items-center text-sm font-medium text-body underline underline-offset-[3px] decoration-body/40 hover:text-heading hover:decoration-heading/60 transition-colors duration-150">
      See all the ways to start
    </a>
    <span class="min-h-11 inline-flex items-center text-[13.5px] text-meta-sage">
      In crisis right now?&nbsp;<a href="#crisis" data-quiz-crisis-link class="pathway-quiz-crisis-link font-semibold text-accent-red-soft border-b-[1.5px] border-accent-red-soft/30">Get crisis support</a>
    </span>
  </div>
</div>

<script>
  import '../scripts/pathway-quiz.ts';
</script>

<style>
  /* The intro screen carries flex classes, which would defeat [hidden] without this. */
  .pathway-quiz-screen[hidden] {
    display: none;
  }

  .pathway-quiz-answer-list {
    display: grid;
    gap: 0.75rem;
  }

  .pathway-quiz-answer {
    min-height: 3.5rem;
    width: 100%;
    border: 1px solid color-mix(in srgb, var(--color-ink-green) 16%, transparent);
    border-radius: 0.625rem;
    background: white;
    color: var(--color-heading);
    padding: 0.875rem 1rem;
    text-align: left;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
  }

  .pathway-quiz-answer:hover {
    border-color: var(--color-primary);
    background: var(--color-primary-light);
  }

  .pathway-quiz-answer:disabled {
    cursor: wait;
    opacity: 0.7;
  }

  .pathway-quiz-answer:focus-visible,
  .pathway-quiz-primary-button:focus-visible,
  .pathway-quiz-secondary-button:focus-visible,
  .pathway-quiz-rail-link:focus-visible,
  .pathway-quiz-crisis-link:focus-visible {
    outline: 3px solid var(--color-primary);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: no-preference) {
    .pathway-quiz-screen:not([hidden]) {
      animation: pathwayQuizEnter 180ms ease-out;
    }
  }

  @keyframes pathwayQuizEnter {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
