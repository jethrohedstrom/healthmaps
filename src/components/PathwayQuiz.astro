---
import { emphasisSegments, resultContent, scoredPathwayIds } from '../data/pathway-quiz-results';

// Every possible result's copy, for the invisible sizer that keeps the card
// height stable no matter which result renders.
const resultVariants = scoredPathwayIds.map((id) => resultContent[id]);

// Scores map to pathway-quiz.ts weights; keys are emitted verbatim as
// data-score-* attributes on the answer buttons.
const questions: { question: string; answers: { label: string; scores: Record<string, number> }[] }[] = [
  {
    question: 'What matters most to you right now?',
    answers: [
      { label: 'Getting seen as fast as possible', scores: { 'data-score-private': 3, 'data-score-self-guided': 1 } },
      { label: 'Keeping the cost down', scores: { 'data-score-low-cost': 3, 'data-score-through-gp': 1, 'data-score-self-guided': 1 } },
      { label: "Finding someone who's the right fit", scores: { 'data-score-private': 3, 'data-score-through-gp': 1 } },
      { label: "I'm not sure yet", scores: { 'data-score-through-gp': 1 } },
    ],
  },
  {
    question: 'When it comes to cost, what fits you best right now?',
    answers: [
      { label: "I'd like Medicare rebates to help with the cost", scores: { 'data-score-through-gp': 3 } },
      { label: "I'm not really concerned about cost", scores: { 'data-score-private': 3 } },
      { label: 'I need free or very low-cost options', scores: { 'data-score-low-cost': 3, 'data-score-self-guided': 1 } },
    ],
  },
  {
    question: 'How would you prefer to start?',
    answers: [
      { label: "By getting a GP's advice first", scores: { 'data-score-through-gp': 2, 'data-score-low-cost': 1 } },
      { label: 'Straight to a therapist', scores: { 'data-score-private': 2, 'data-score-through-gp': 1 } },
      { label: 'On my own, online, at my own pace', scores: { 'data-score-self-guided': 3 } },
      { label: 'Through free or community services', scores: { 'data-score-low-cost': 3 } },
    ],
  },
  {
    question: 'Do you have a regular GP you can see?',
    answers: [
      { label: 'Yes', scores: { 'data-score-through-gp': 3 } },
      { label: 'I can get to one, but it may take a little time', scores: { 'data-score-through-gp': 2 } },
      { label: 'No / not sure', scores: { 'data-score-low-cost': 1, 'data-score-private': 1, 'data-score-self-guided': 1 } },
    ],
  },
];
---

<!-- Flat quiz card (design handoff 6a, simplified). Deliberately no box-shadow.
     The wrapper exists so the station-label badge can overhang the top border
     without being clipped by the shell's overflow-hidden. -->
<div class="relative max-w-[640px] mx-auto">
<div data-pathway-quiz class="text-left bg-paper-cream border border-pencil rounded-[14px] overflow-hidden">
  <p class="sr-only" aria-live="polite" aria-atomic="true" data-quiz-live></p>

  <div data-quiz-screen="intro" class="pathway-quiz-screen pathway-quiz-screen--intro px-8 py-10 sm:px-12 sm:py-12 text-center">
    <!-- Route motif: four stops (the four questions), filled terminus (your suggested step). -->
    <svg class="mx-auto mb-6 text-primary" width="88" height="10" viewBox="0 0 88 10" fill="none" aria-hidden="true">
      <line x1="5" y1="5" x2="83" y2="5" stroke="currentColor" stroke-opacity="0.25" stroke-width="1.5" />
      <circle cx="5" cy="5" r="3" fill="currentColor" fill-opacity="0.35" />
      <circle cx="31" cy="5" r="3" fill="currentColor" fill-opacity="0.35" />
      <circle cx="57" cy="5" r="3" fill="currentColor" fill-opacity="0.35" />
      <circle cx="83" cy="5" r="4" fill="currentColor" />
    </svg>
    <h2 tabindex="-1" data-quiz-heading class="pathway-quiz-heading pathway-quiz-heading--intro">
      Not sure where to start?
    </h2>
    <p class="text-[15.5px] leading-[1.55] text-body mt-[10px] max-w-[480px] mx-auto">
      Four quick questions, then a suggested first step for your situation.
    </p>
    <button type="button" data-quiz-start class="pathway-quiz-primary-button w-full sm:w-auto min-h-11 rounded-[10px] bg-primary hover:bg-primary-dark transition-colors duration-150 px-5 sm:px-9 py-[13px] text-center text-base font-semibold text-white mt-7">
      Start the quiz
    </button>
    <p class="text-[13px] text-meta-sage mt-[14px]">2 minutes &middot; no sign-up &middot; stays in your browser</p>
  </div>

  {questions.map(({ question, answers }, index) => (
    <div data-quiz-screen="question" data-question-index={index} class="pathway-quiz-screen pathway-quiz-screen--hidden pt-[30px] px-8 pb-8">
      <div class="pathway-quiz-step-row">
        <p class="pathway-quiz-step-label">Question {index + 1} of {questions.length}</p>
        <button type="button" data-quiz-back class="pathway-quiz-back-button">&larr; Back</button>
      </div>
      <h2 tabindex="-1" data-quiz-heading class="pathway-quiz-heading mb-4">
        {question}
      </h2>
      <div class="pathway-quiz-answer-list" role="group" aria-label={question}>
        {answers.map(({ label, scores }) => (
          <button type="button" data-quiz-answer data-answer-label={label} {...scores} class="pathway-quiz-answer">
            {label}
          </button>
        ))}
      </div>
    </div>
  ))}

  <div data-quiz-screen="result" class="pathway-quiz-screen pathway-quiz-screen--hidden pt-[30px] px-8 pb-8">
    <div class="pathway-quiz-step-row">
      <p class="pathway-quiz-step-label">Our suggestion</p>
      <button type="button" data-quiz-back class="pathway-quiz-back-button">&larr; Back</button>
    </div>
    <h2 tabindex="-1" data-quiz-heading data-result-title class="pathway-quiz-heading mb-4">
      Your result
    </h2>
    <ul data-result-summary class="pathway-quiz-result-points text-[15.5px] leading-[1.55] text-body mb-6"></ul>
    <div class="flex flex-col sm:flex-row gap-3">
      <a href="#through-gp" data-result-link class="pathway-quiz-primary-button inline-flex min-h-11 items-center justify-center rounded-[10px] bg-primary hover:bg-primary-dark transition-colors duration-150 px-6 py-[13px] text-base font-semibold text-white">
        Show me the steps
      </a>
      <button type="button" data-quiz-reset class="pathway-quiz-secondary-button min-h-11 rounded-[10px] border border-ink-green/16 bg-transparent hover:bg-row-hover transition-colors duration-150 px-6 py-[13px] text-base font-semibold text-heading">
        Start over
      </button>
    </div>
    <p class="text-[13.5px] leading-[1.55] text-meta-sage mt-5">
      Another good option &mdash; <span data-runner-up></span>
    </p>
  </div>

  <!-- Invisible height sizer: the result screen's copy is injected at runtime,
       so this block stacks ALL possible result copy variants (in nested grid
       cells) to guarantee the card never resizes when a result renders.
       Non-interactive elements only; no data-quiz-screen / data-result-*
       attributes, so the quiz script ignores it entirely. -->
  <div class="pathway-quiz-sizer pt-[30px] px-8 pb-8" aria-hidden="true">
    <div class="pathway-quiz-step-row">
      <p class="pathway-quiz-step-label">Our suggestion</p>
      <span class="pathway-quiz-back-button">&larr; Back</span>
    </div>
    <div class="pathway-quiz-stack mb-4">
      {resultVariants.map((variant) => <p class="pathway-quiz-heading">{variant.title}</p>)}
    </div>
    <div class="pathway-quiz-stack mb-6">
      {resultVariants.map((variant) => (
        <ul class="pathway-quiz-result-points text-[15.5px] leading-[1.55] text-body">
          {variant.summaryPoints.map((point) => (
            <li>{emphasisSegments(point).map((segment) => (segment.em ? <em>{segment.text}</em> : segment.text))}</li>
          ))}
        </ul>
      ))}
    </div>
    <div class="flex flex-col sm:flex-row gap-3">
      <span class="pathway-quiz-primary-button inline-flex min-h-11 items-center justify-center rounded-[10px] bg-primary px-6 py-[13px] text-base font-semibold text-white">
        Show me the steps
      </span>
      <span class="pathway-quiz-secondary-button min-h-11 rounded-[10px] border border-ink-green/16 px-6 py-[13px] text-base font-semibold text-heading">
        Start over
      </span>
    </div>
    <div class="pathway-quiz-stack text-[13.5px] leading-[1.55] text-meta-sage mt-5">
      {resultVariants.map((variant) => (
        <p>Another good option &mdash; {variant.title}: {variant.secondarySummary}</p>
      ))}
    </div>
  </div>

</div>

<!-- Station label: overhangs the card border like a stop on the map. Shown by
     pathway-quiz.ts only when the result is the GP route. -->
<div data-result-badge class="hidden absolute -top-[14px] right-7 items-center gap-[7px] rounded-full border border-pencil bg-paper-cream py-1 pl-[9px] pr-3">
  <span class="h-[9px] w-[9px] rounded-full border-[2.5px] border-primary bg-white" aria-hidden="true"></span>
  <span class="text-[12.5px] font-semibold text-primary">Most people start here</span>
</div>
</div>

<script>
  import '../scripts/pathway-quiz.ts';
</script>

<style>
  /* Clears the sticky header (top) and leaves breathing room at the viewport
     edge (bottom) when the quiz scrolls itself into view. */
  [data-pathway-quiz] {
    scroll-margin-top: 5.5rem;
    scroll-margin-bottom: 4rem;
  }

  /* All screens (and the result sizer) share one grid cell, so the card takes
     the height of its tallest screen and never resizes between screens — the
     section below stays put. Inactive screens must therefore stay display:
     block and hide via visibility, which also removes them from the a11y tree
     and tab order. A class (not the hidden attribute) toggles them because
     Tailwind's preflight forces [hidden] to display: none !important. */
  [data-pathway-quiz] {
    display: grid;
  }

  .pathway-quiz-screen,
  .pathway-quiz-sizer {
    grid-area: 1 / 1;
  }

  .pathway-quiz-screen--hidden {
    opacity: 0;
    visibility: hidden;
    /* Inert immediately, even while still fading out. */
    pointer-events: none;
  }

  .pathway-quiz-sizer {
    visibility: hidden;
  }

  /* Stacks all copy variants in one cell so each sizer slot is as tall as its
     tallest variant at every breakpoint. */
  .pathway-quiz-stack {
    display: grid;
  }

  .pathway-quiz-stack > :global(*) {
    grid-area: 1 / 1;
  }

  /* Shared screen typography (design handoff 6a: Switzer 600 23px / -0.012em). */
  .pathway-quiz-heading {
    font-family: var(--font-display);
    font-size: 23px;
    font-weight: 600;
    letter-spacing: -0.012em;
    line-height: 1.375;
    color: var(--color-heading);
  }

  /* The intro is the card's "cover" — slightly larger than the working screens. */
  .pathway-quiz-heading--intro {
    font-size: 26px;
  }

  /* Fixed card height leaves spare room on the short intro; centre it so the
     empty space sits evenly above and below instead of as a blank slab under
     the CTA. Question/result screens stay top-aligned. */
  .pathway-quiz-screen--intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  /* Result summary points: small primary-green route dots, echoing the
     four-stop motif on the intro screen. Preflight already strips list style. */
  .pathway-quiz-result-points {
    display: grid;
    gap: 0.5rem;
  }

  .pathway-quiz-result-points :global(li) {
    position: relative;
    padding-left: 1.125rem;
  }

  .pathway-quiz-result-points :global(li)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: var(--color-primary);
  }

  .pathway-quiz-step-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .pathway-quiz-step-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-primary);
  }

  .pathway-quiz-back-button {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-body);
  }

  .pathway-quiz-back-button:hover {
    color: var(--color-heading);
  }

  .pathway-quiz-answer-list {
    display: grid;
    gap: 0.75rem;
  }

  .pathway-quiz-answer {
    min-height: 3.5rem;
    width: 100%;
    border: 1px solid color-mix(in srgb, var(--color-ink-green) 16%, transparent);
    border-radius: 0.625rem;
    background: white;
    color: var(--color-body);
    padding: 0.875rem 1rem;
    text-align: left;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.4;
  }

  .pathway-quiz-answer:hover {
    border-color: var(--color-primary);
    background: var(--color-primary-light);
    color: var(--color-heading);
  }

  .pathway-quiz-answer:disabled {
    cursor: wait;
    opacity: 0.7;
  }

  .pathway-quiz-answer:focus-visible,
  .pathway-quiz-primary-button:focus-visible,
  .pathway-quiz-secondary-button:focus-visible,
  .pathway-quiz-back-button:focus-visible {
    outline: 3px solid var(--color-primary);
    outline-offset: 3px;
  }

  /* Sequenced fade between screens: the outgoing screen fades out quickly,
     then the incoming one fades in with a soft rise. Both occupy the same
     grid cell, so no layout moves. Reduced motion gets the instant swap from
     the base rules above. */
  @media (prefers-reduced-motion: no-preference) {
    .pathway-quiz-screen {
      transition:
        opacity 240ms ease-out 110ms,
        transform 240ms ease-out 110ms,
        visibility 0s 0s;
    }

    .pathway-quiz-screen--hidden {
      transform: translateY(6px);
      transition:
        opacity 140ms ease-in,
        transform 140ms ease-in,
        visibility 0s 140ms;
    }
  }
</style>
