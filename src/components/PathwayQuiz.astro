---
// Scores map to pathway-quiz.ts weights; keys are emitted verbatim as
// data-score-* attributes on the answer buttons.
const questions: { question: string; answers: { label: string; scores: Record<string, number> }[] }[] = [
  {
    question: 'What matters most to you right now?',
    answers: [
      { label: 'Getting seen as fast as possible', scores: { 'data-score-private': 3, 'data-score-self-guided': 1 } },
      { label: 'Keeping the cost down', scores: { 'data-score-low-cost': 3, 'data-score-through-gp': 1, 'data-score-self-guided': 1 } },
      { label: 'Finding the right kind of person', scores: { 'data-score-private': 3, 'data-score-through-gp': 1 } },
      { label: "I'm not sure yet", scores: { 'data-score-through-gp': 1 } },
    ],
  },
  {
    question: 'When it comes to cost, what fits you best right now?',
    answers: [
      { label: "I'll go the regular route to keep costs down", scores: { 'data-score-through-gp': 3 } },
      { label: "I'm not really concerned about cost", scores: { 'data-score-private': 3 } },
      { label: 'I need free or very low-cost options', scores: { 'data-score-low-cost': 3, 'data-score-self-guided': 1 } },
    ],
  },
  {
    question: 'How would you prefer to start?',
    answers: [
      { label: 'With a doctor who can point me in the right direction', scores: { 'data-score-through-gp': 2, 'data-score-low-cost': 1 } },
      { label: 'Straight to a therapist', scores: { 'data-score-private': 2, 'data-score-through-gp': 1 } },
      { label: 'On my own, online, at my own pace', scores: { 'data-score-self-guided': 3 } },
      { label: 'Through free or community services', scores: { 'data-score-low-cost': 3 } },
    ],
  },
  {
    question: 'Do you have a regular GP you can see?',
    answers: [
      { label: 'Yes', scores: { 'data-score-through-gp': 3 } },
      { label: 'I can get to one, but it may take a little time', scores: { 'data-score-through-gp': 2 } },
      { label: 'No / not sure', scores: { 'data-score-low-cost': 1, 'data-score-private': 1, 'data-score-self-guided': 1 } },
    ],
  },
];
---

<!-- Flat split quiz card (design handoff 6a). Deliberately no box-shadow.
     The bottom rail sits outside the screens but inside [data-pathway-quiz],
     so it persists on every quiz screen and event delegation still reaches it. -->
<div data-pathway-quiz class="max-w-[640px] mx-auto text-left bg-paper-cream border border-ink-green/16 rounded-[14px] overflow-hidden">
  <p class="sr-only" aria-live="polite" aria-atomic="true" data-quiz-live></p>

  <div data-quiz-screen="intro" class="pathway-quiz-screen flex flex-col sm:flex-row sm:items-stretch">
    <div class="sm:flex-[1.3] pt-[30px] px-8 pb-[26px]">
      <h2 tabindex="-1" data-quiz-heading class="pathway-quiz-heading">
        Not sure where to start?
      </h2>
      <p class="text-[15.5px] leading-[1.55] text-body mt-[9px]">
        Answer four quick questions and we&rsquo;ll suggest a good first step for your situation.
      </p>
    </div>
    <div class="shrink-0 h-px mx-8 bg-ink-green/12 sm:h-auto sm:w-px sm:mx-0 sm:my-[22px]"></div>
    <div class="sm:flex-1 py-[26px] px-8 flex flex-col justify-center gap-[13px]">
      <button type="button" data-quiz-start class="pathway-quiz-primary-button w-full min-h-11 rounded-[10px] bg-primary hover:bg-primary-dark transition-colors duration-150 px-5 py-[13px] text-center text-base font-semibold text-white">
        Start the quiz
      </button>
      <ul class="flex flex-col gap-[5px] text-[13px] text-meta-sage" role="list">
        <li class="flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-primary opacity-55 shrink-0" aria-hidden="true"></span>&#8776; 2 minutes</li>
        <li class="flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-primary opacity-55 shrink-0" aria-hidden="true"></span>No sign-up</li>
        <li class="flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-primary opacity-55 shrink-0" aria-hidden="true"></span>Stays in your browser</li>
      </ul>
    </div>
  </div>

  {questions.map(({ question, answers }, index) => (
    <div data-quiz-screen="question" data-question-index={index} class="pathway-quiz-screen pt-[30px] px-8 pb-8" hidden>
      <p class="pathway-quiz-step-label">Question {index + 1} of {questions.length}</p>
      <h2 tabindex="-1" data-quiz-heading class="pathway-quiz-heading mb-4">
        {question}
      </h2>
      <div class="pathway-quiz-answer-list" role="group" aria-label={question}>
        {answers.map(({ label, scores }) => (
          <button type="button" data-quiz-answer data-answer-label={label} {...scores} class="pathway-quiz-answer">
            {label}
          </button>
        ))}
      </div>
    </div>
  ))}

  <div data-quiz-screen="result" class="pathway-quiz-screen pt-[30px] px-8 pb-8" hidden>
    <p class="pathway-quiz-step-label">Suggested starting point</p>
    <h2 tabindex="-1" data-quiz-heading data-result-title class="pathway-quiz-heading mb-4">
      Your result
    </h2>
    <p data-result-summary class="text-[15.5px] leading-[1.55] text-body mb-6"></p>
    <div class="rounded-[10px] border border-ink-green/12 p-4 mb-6">
      <p class="text-sm font-semibold text-heading mb-1">Another good option</p>
      <p data-runner-up class="text-[15.5px] leading-[1.55] text-body"></p>
    </div>
    <div class="flex flex-col sm:flex-row gap-3">
      <a href="#through-gp" data-result-link class="pathway-quiz-primary-button inline-flex min-h-11 items-center justify-center rounded-[10px] bg-primary hover:bg-primary-dark transition-colors duration-150 px-6 py-[13px] text-base font-semibold text-white">
        Go to this pathway
      </a>
      <button type="button" data-quiz-reset class="pathway-quiz-secondary-button min-h-11 rounded-[10px] border border-ink-green/16 bg-transparent hover:bg-row-hover transition-colors duration-150 px-6 py-[13px] text-base font-semibold text-heading">
        Start over
      </button>
    </div>
  </div>

  <div class="border-t border-ink-green/12 px-8 py-1 flex flex-wrap items-center justify-between gap-x-4">
    <a href="#all-the-ways" class="pathway-quiz-rail-link min-h-11 inline-flex items-center text-sm font-medium text-body underline underline-offset-[3px] decoration-body/40 hover:text-heading hover:decoration-heading/60 transition-colors duration-150">
      See all the ways to start
    </a>
    <span class="min-h-11 inline-flex items-center text-[13.5px] text-meta-sage">
      In crisis right now?&nbsp;<a href="#crisis" data-quiz-crisis-link class="pathway-quiz-crisis-link font-semibold text-accent-red-soft border-b-[1.5px] border-accent-red-soft/30">Get crisis support</a>
    </span>
  </div>
</div>

<script>
  import '../scripts/pathway-quiz.ts';
</script>

<style>
  /* The intro screen carries flex classes, which would defeat [hidden] without this. */
  .pathway-quiz-screen[hidden] {
    display: none;
  }

  /* Shared screen typography (design handoff 6a: Switzer 600 23px / -0.012em). */
  .pathway-quiz-heading {
    font-family: var(--font-display);
    font-size: 23px;
    font-weight: 600;
    letter-spacing: -0.012em;
    line-height: 1.375;
    color: var(--color-heading);
  }

  .pathway-quiz-step-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }

  .pathway-quiz-answer-list {
    display: grid;
    gap: 0.75rem;
  }

  .pathway-quiz-answer {
    min-height: 3.5rem;
    width: 100%;
    border: 1px solid color-mix(in srgb, var(--color-ink-green) 16%, transparent);
    border-radius: 0.625rem;
    background: white;
    color: var(--color-heading);
    padding: 0.875rem 1rem;
    text-align: left;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
  }

  .pathway-quiz-answer:hover {
    border-color: var(--color-primary);
    background: var(--color-primary-light);
  }

  .pathway-quiz-answer:disabled {
    cursor: wait;
    opacity: 0.7;
  }

  .pathway-quiz-answer:focus-visible,
  .pathway-quiz-primary-button:focus-visible,
  .pathway-quiz-secondary-button:focus-visible,
  .pathway-quiz-rail-link:focus-visible,
  .pathway-quiz-crisis-link:focus-visible {
    outline: 3px solid var(--color-primary);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: no-preference) {
    .pathway-quiz-screen:not([hidden]) {
      animation: pathwayQuizEnter 180ms ease-out;
    }
  }

  @keyframes pathwayQuizEnter {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
