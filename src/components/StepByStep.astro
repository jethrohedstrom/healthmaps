---
interface Step {
  number: number;
  title: string;
  detail: string;
}

interface Props {
  steps: Step[];
}

const { steps } = Astro.props;
---

<ol class="relative">
  {steps.map((step, index) => {
    const isLast = index === steps.length - 1;
    return (
      <li class="pathway-step relative pl-14 md:pl-16 pb-6 last:pb-0">
        {/* Vertical connector line */}
        {!isLast && (
          <div class="step-connector absolute left-[19px] top-10 bottom-0 w-px bg-border" aria-hidden="true" />
        )}

        {/* Numbered circle */}
        <div class="step-circle absolute left-0 top-0 w-10 h-10 rounded-full border-2 border-border bg-white flex items-center justify-center font-bold text-sm text-body z-10" aria-hidden="true">
          {step.number}
        </div>

        {/* Step content */}
        <p class="font-semibold text-heading min-h-[40px] flex items-center">{step.title}</p>
        <div class="prose mt-1 text-base leading-relaxed text-body" set:html={step.detail} />
      </li>
    );
  })}
</ol>
