---
import PathwayTimeHorizon from './PathwayTimeHorizon.astro';
import type { PathwayCard } from '../data/pathway-cards';

interface Props extends PathwayCard {}

const { id, title, bestFor, badge, steps, timeHorizon } = Astro.props;
---

<div id={id} data-pathway-card data-progressive-card data-legacy-step-hash class="pathway-card-clickable rounded-xl border border-border shadow-sm bg-white p-6 md:p-8 flex flex-col">
  {/* L0: always visible */}
  <div class="mb-3">
    {badge && (
      <p class="text-xs font-semibold uppercase tracking-widest text-body mb-2">{badge}</p>
    )}
    <h3 class="text-xl md:text-2xl font-bold text-heading leading-snug">{title}</h3>
  </div>

  <p class="text-base leading-relaxed text-body mb-7">{bestFor}</p>

  {/* L1 */}
  <details class="pathway-details-toggle">
    <summary class="inline-flex items-center text-sm font-semibold text-primary cursor-pointer select-none hover:text-primary-mid transition-colors">
      <span class="sr-only">{title}: </span>
      <span class="pathway-label-show">Show details</span>
      <span class="pathway-label-hide">Hide details</span>
    </summary>
    <div class="pathway-l1-body mt-5">
      {/*
        L1 facts are hardcoded here (rather than read from facts.cost / facts.sessions)
        so the headline number can be bolded and the qualifier kept regular weight.
        If the canonical strings in pathway-cards.ts change for the GP card, update them here too.
      */}
      <dl class="pathway-facts text-sm border-y border-border divide-y divide-border mb-4">
        <div class="flex justify-between gap-4 py-2.5">
          <dt class="text-body">Cost</dt>
          <dd class="font-medium text-heading text-right"><span class="font-semibold">$50&ndash;$200</span> per session</dd>
        </div>
        <div class="flex justify-between gap-4 py-2.5">
          <dt class="text-body">Sessions</dt>
          <dd class="font-medium text-heading text-right"><span class="font-semibold">Up to 10</span> per year</dd>
        </div>
      </dl>
      <div class="mb-6">
        <PathwayTimeHorizon events={timeHorizon?.events} />
      </div>

      {/* L2 */}
      <details class="pathway-details-toggle pathway-details-toggle--nested">
        <summary class="inline-flex items-center text-sm font-semibold text-primary cursor-pointer select-none hover:text-primary-mid transition-colors">
          <span class="sr-only">{title}: </span>
          <span class="pathway-label-show">How does this work?</span>
          <span class="pathway-label-hide">Hide steps</span>
        </summary>
        <ol class="pathway-step-accordions mt-4" data-step-reveal data-step-total={steps.length}>
          {steps.map((step, idx) => (
            <li id={`step-${step.number}`} class="scroll-mt-24" data-step-index={step.number} hidden={idx > 0}>
              <details class="pathway-step-item">
                <summary class="pathway-step-summary">
                  <span class="pathway-step-number" aria-hidden="true">{step.number}</span>
                  <span class="pathway-step-title">{step.title}</span>
                </summary>
                <div class="pathway-step-detail prose" set:html={step.detail} />
              </details>
            </li>
          ))}
        </ol>
        <div class="pathway-gp-progress mt-5 pt-4 border-t border-border">
          <p class="text-xs text-body mb-2" id={`${id}-progress-label`} data-progress-label>
            Step 1 of {steps.length}
          </p>
          <div
            class="pathway-gp-progress-track h-1.5 rounded-full bg-bg-light overflow-hidden"
            role="progressbar"
            aria-valuemin="1"
            aria-valuemax={steps.length}
            aria-valuenow="1"
            aria-labelledby={`${id}-progress-label`}
            data-progressbar
          >
            <div
              class="pathway-gp-progress-fill h-full bg-primary pathway-gp-progress-fill-motion"
              style={`width: ${(100 / steps.length).toFixed(4)}%`}
              data-progress-fill
            />
          </div>
          <p class="sr-only" aria-live="polite" aria-atomic="true" data-progress-live></p>
        </div>
      </details>
    </div>
  </details>
</div>

{/*
  Tap-anywhere-to-toggle: pathway-card-click.ts (imported from pathway.astro).
*/}
<script>
  import '../scripts/pathway-progressive-steps.ts';
</script>
