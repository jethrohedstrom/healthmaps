---
import PathwayIcon from './PathwayIcon.astro';
import { iconStyleMap } from '../data/pathway-cards';
import type { PathwayCard } from '../data/pathway-cards';

interface Props extends PathwayCard {}

const { id, icon, title, bestFor, accentColor, badge, steps } = Astro.props;

const accentTopBorder = accentColor.replace('border-l-', 'border-t-');
const iconStyle = iconStyleMap[icon] ?? { bg: 'bg-primary-light', stroke: 'text-primary' };
---

<div id={id} data-pathway-card class={`pathway-card-clickable rounded-xl shadow-sm border-t-4 ${accentTopBorder} bg-white p-6 md:p-8 flex flex-col`}>
  {/* L0: always visible */}
  <div class={`w-12 h-12 ${iconStyle.bg} rounded-xl flex items-center justify-center mb-5`}>
    <PathwayIcon icon={icon} class={`w-6 h-6 ${iconStyle.stroke}`} />
  </div>

  <div class="mb-3">
    {badge && (
      <span class="inline-block text-xs font-semibold text-white bg-primary px-3 py-1 rounded-full mb-2">{badge}</span>
    )}
    <h3 class="text-xl md:text-2xl font-bold text-heading leading-snug">{title}</h3>
  </div>

  <p class="text-base leading-relaxed text-body mb-5">{bestFor}</p>

  {/* L1 */}
  <details class="pathway-details-toggle">
    <summary class="inline-flex items-center text-sm font-semibold text-primary cursor-pointer select-none hover:text-primary-mid transition-colors">
      <span class="sr-only">{title}: </span>
      <span class="pathway-label-show">Show details</span>
      <span class="pathway-label-hide">Hide details</span>
    </summary>
    <div class="pathway-l1-body mt-5">
      {/*
        L1 pills are hardcoded here (rather than read from facts.cost / facts.sessions)
        so the headline number can be bolded and the qualifier kept regular weight.
        If the canonical strings in pathway-cards.ts change for the GP card, update them here too.
      */}
      <div class="flex flex-wrap gap-2 mb-6">
        <span class="inline-flex items-center gap-1.5 text-sm bg-bg-light px-3 py-1.5 rounded-lg">
          <span class="text-body">Cost:</span>
          <span class="font-semibold text-heading">$50&ndash;$200</span>
          <span class="text-body">per session</span>
        </span>
        <span class="inline-flex items-center gap-1.5 text-sm bg-bg-light px-3 py-1.5 rounded-lg">
          <span class="text-body">Sessions:</span>
          <span class="font-semibold text-heading">Up to 10</span>
          <span class="text-body">per year</span>
        </span>
        {/*
          V6a — single shared horizon with two pins.
          Replaces the previous two linear progress bars; the bars implied a
          precision the underlying "a few days" / "a few weeks" copy doesn't
          have. Pin positions are fixed per copy bucket — see
          design_handoff_time_horizon/README.md for the bucket → percentage
          table. Do not compute positions from raw day counts.
        */}
        <div class="time-horizon w-full" role="group" aria-label="Time to first appointment">
          <div class="time-horizon__label">Time to first appointment</div>
          <div class="time-horizon__track-wrap">
            <div class="time-horizon__track" aria-hidden="true"></div>

            <div class="time-horizon__pin" style="left: 12%;">
              <div class="time-horizon__pin-stem" aria-hidden="true"></div>
              <div class="time-horizon__pin-dot" aria-hidden="true"></div>
              <div class="time-horizon__pin-label">GP</div>
              <div class="time-horizon__pin-sub">a few days</div>
            </div>

            <div class="time-horizon__pin" style="left: 68%;">
              <div class="time-horizon__pin-stem" aria-hidden="true"></div>
              <div class="time-horizon__pin-dot" aria-hidden="true"></div>
              <div class="time-horizon__pin-label">Practitioner</div>
              <div class="time-horizon__pin-sub">a few weeks</div>
            </div>

            <span class="time-horizon__cap time-horizon__cap--left">Today</span>
            <span class="time-horizon__cap time-horizon__cap--right">1 month</span>
          </div>
        </div>
      </div>

      {/* L2 */}
      <details class="pathway-details-toggle pathway-details-toggle--nested">
        <summary class="inline-flex items-center text-sm font-semibold text-primary cursor-pointer select-none hover:text-primary-mid transition-colors">
          <span class="sr-only">{title}: </span>
          <span class="pathway-label-show">How does this work?</span>
          <span class="pathway-label-hide">Hide steps</span>
        </summary>
        <ol class="pathway-step-accordions mt-4">
          {steps.map((step) => (
            <li>
              <details class="pathway-step-item">
                <summary class="pathway-step-summary">
                  <span class="pathway-step-number" aria-hidden="true">{step.number}</span>
                  <span class="pathway-step-title">{step.title}</span>
                </summary>
                <div class="pathway-step-detail prose" set:html={step.detail} />
              </details>
            </li>
          ))}
        </ol>
      </details>
    </div>
  </details>
</div>

{/* Tap-anywhere-to-toggle handler lives in PathwayCardVisual.astro, which
    queries all [data-pathway-card] elements on the page — so the GP card
    is wired up there automatically. Duplicating the script here would
    attach two click listeners per card and cancel itself out. */}

<style>
  /* V6a time horizon: shared timeline with two pins.
     Spec: design_handoff_time_horizon/README.md. All values are deliberate —
     don't tweak in isolation; check the reference HTML alongside. */
  .time-horizon {
    background: var(--color-bg-light);
    padding: 22px 24px 18px;
    border-radius: 8px;
    position: relative;
  }
  .time-horizon__label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-body);
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .time-horizon__track-wrap {
    position: relative;
    /* 94px (vs the reference's 80px) gives the caps their own row beneath the
       pin sub-text. The reference assumes a 480px card; ours sits in a 2-col
       grid at ~440px, so caps + pin labels collide on the same row. */
    height: 94px;
    margin-top: 10px;
  }
  .time-horizon__track {
    position: absolute;
    left: 0;
    right: 0;
    top: 14px;
    height: 6px;
    border-radius: 999px;
    background: linear-gradient(to right, var(--color-primary-light), #f1f5f3);
  }
  .time-horizon__pin {
    position: absolute;
    top: -2px;
    transform: translateX(-50%);
    text-align: center;
  }
  .time-horizon__pin-stem {
    width: 2px;
    height: 14px;
    margin: 0 auto;
    background: var(--color-primary);
  }
  .time-horizon__pin-dot {
    width: 12px;
    height: 12px;
    margin: 0 auto;
    border-radius: 999px;
    background: var(--color-primary);
    /* White ring knocks the dot out of the track cleanly. */
    box-shadow: 0 0 0 4px white;
  }
  .time-horizon__pin-label {
    margin-top: 8px;
    font-size: 12px;
    font-weight: 600;
    color: var(--color-heading);
    white-space: nowrap;
  }
  .time-horizon__pin-sub {
    font-size: 11px;
    color: var(--color-body);
    white-space: nowrap;
  }
  .time-horizon__cap {
    position: absolute;
    /* Caps sit on their own row below the pin labels (instead of the
       reference's top: 38px, which shares a row with the labels and collides
       at our narrower card width). 74px = pin-sub bottom (~69px with our
       1.625 body line-height) + ~5px breathing room. */
    top: 74px;
    font-size: 10px;
    color: var(--color-body);
  }
  .time-horizon__cap--left  { left: 0; }
  .time-horizon__cap--right { right: 0; }

  /* Narrow viewports: drop the section label + right cap; keep "Today" and pins. */
  @media (max-width: 359px) {
    .time-horizon__label,
    .time-horizon__cap--right {
      display: none;
    }
  }
</style>
