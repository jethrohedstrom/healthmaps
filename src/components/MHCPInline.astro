---
interface Props {
  variant?: 'full' | 'acronym';
}

const { variant = 'full' } = Astro.props;
const label = variant === 'acronym' ? 'MHCP' : 'Mental Health Care Plan (MHCP)';
---
<span class="mhcp-inline">
  <button
    type="button"
    class="mhcp-inline-toggle text-primary font-semibold underline underline-offset-2 cursor-pointer hover:text-primary/80 transition-colors bg-transparent border-0 p-0 text-inherit"
  >{label}</button>
  <span
    class="mhcp-inline-explanation block overflow-hidden max-h-0 opacity-0 transition-all duration-300 ease-out"
    aria-hidden="true"
  >
    <span class="block bg-white rounded-lg p-4 mt-3 text-sm text-body leading-relaxed border-l-[3px] border-primary/40">
      <span class="block font-semibold text-heading mb-1">What is a Mental Health Care Plan?</span>
      <span class="block">A document your GP creates during your appointment that unlocks Medicare rebates for up to 10 psychology sessions per calendar year. Your GP handles it all, with no extra paperwork on your end.</span>
      <a
        href="/pathway/#step-2"
        class="inline-flex items-center gap-1 text-primary font-semibold mt-2 hover:text-primary/80 transition-colors text-xs"
      >
        Learn more about the process
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
      </a>
    </span>
  </span>
</span>

<script>
  document.querySelectorAll<HTMLButtonElement>('.mhcp-inline-toggle').forEach((btn) => {
    const explanation = btn.parentElement?.querySelector<HTMLElement>('.mhcp-inline-explanation');
    if (!explanation) return;
    btn.addEventListener('click', () => {
      const isOpen = explanation.classList.contains('max-h-96');
      if (isOpen) {
        explanation.classList.remove('max-h-96', 'opacity-100');
        explanation.classList.add('max-h-0', 'opacity-0');
        explanation.setAttribute('aria-hidden', 'true');
      } else {
        explanation.classList.remove('max-h-0', 'opacity-0');
        explanation.classList.add('max-h-96', 'opacity-100');
        explanation.setAttribute('aria-hidden', 'false');
      }
    });
  });
</script>
