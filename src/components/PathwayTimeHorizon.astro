---
import { WAIT_BUCKETS, type PathwayTimelineEvent } from '../data/pathway-time-horizon';

interface Props {
  events?: PathwayTimelineEvent[];
}

const W = 432;
// The drawing is laid out in a 432x220 space, but nothing is drawn above y=36
// or below y=207.5 (checked with getBBox on every card). The viewBox crops to
// the ink so the panel isn't padded out by ~30px of blank canvas; all the
// coordinate constants below stay in the original 220-tall space.
const VIEW_Y = 30;
const VIEW_H = 184;
const PAD_X = 24;
const CY = 92;
const AMP = 22;
const USABLE_W = W - PAD_X * 2;
const TODAY_POS = 3;

const ZONE_LABEL_Y = 204;
const ZONE_BASELINE_Y = 188;
const ZONE_TICK_TOP_Y = 178;
const ZONES = [
  { label: 'DAYS', centerPct: 14 },
  { label: 'WEEKS', centerPct: 44 },
  { label: 'MONTHS', centerPct: 80 },
];
const ZONE_BOUNDARY_PCTS = [28, 60];
const LABEL_MAIN_DY_BELOW = 24;
const LABEL_SUB_DY_BELOW = 36;
const LABEL_MAIN_DY_ABOVE = -24;
const LABEL_SUB_DY_ABOVE = -12;

const { events = [] } = Astro.props;
const hasEvents = events.length > 0;

function xy(pct: number): [number, number] {
  const t = pct / 100;
  const x = PAD_X + t * USABLE_W;
  const y = CY + Math.sin(t * Math.PI * 4) * AMP;
  return [x, y];
}

function pathIsBelow(pct: number): boolean {
  return Math.sin((pct / 100) * Math.PI * 4) >= 0;
}

const pathD = Array.from({ length: 101 }, (_, pct) => {
  const [x, y] = xy(pct);
  return `${pct === 0 ? 'M' : 'L'} ${x.toFixed(2)} ${y.toFixed(2)}`;
}).join(' ');

const todayLabelBelow = pathIsBelow(TODAY_POS);

const positionedEvents = events.map((ev) => ({
  label: ev.label,
  sub: ev.subOverride ?? WAIT_BUCKETS[ev.bucket].sub,
  pos: WAIT_BUCKETS[ev.bucket].pos,
}));

let previousPos = Number.NEGATIVE_INFINITY;
let previousLabelBelow: boolean | null = null;

const labeledEvents = positionedEvents.map((ev) => {
  let labelBelow = pathIsBelow(ev.pos);
  if (Math.abs(ev.pos - previousPos) < 12 && previousLabelBelow !== null) {
    labelBelow = !previousLabelBelow;
  }

  previousPos = ev.pos;
  previousLabelBelow = labelBelow;

  return {
    ...ev,
    labelBelow,
  };
});

const [todayX, todayY] = xy(TODAY_POS);
const todayMainDy = todayLabelBelow ? LABEL_MAIN_DY_BELOW : LABEL_MAIN_DY_ABOVE;

const renderedEvents = labeledEvents.map((ev) => {
  const [x, y] = xy(ev.pos);
  return {
    ...ev,
    x,
    y,
    mainDy: ev.labelBelow ? LABEL_MAIN_DY_BELOW : LABEL_MAIN_DY_ABOVE,
    subDy: ev.labelBelow ? LABEL_SUB_DY_BELOW : LABEL_SUB_DY_ABOVE,
  };
});
---

<div class="winding-path-wrap" role="group" aria-label="Typical timeline">
  <div class="winding-path-inner">
    <div class="winding-path-label">Typical timeline</div>
    {hasEvents ? (
      <svg class="winding-path" viewBox={`0 ${VIEW_Y} ${W} ${VIEW_H}`} preserveAspectRatio="xMidYMid meet">
        <g data-layer="track">
          <path
            d={pathD}
            stroke="var(--color-path)"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-dasharray="3 6"
            fill="none"
            aria-hidden="true"
          />

          <line
            class="winding-path-zone-line"
            x1={PAD_X}
            x2={W - PAD_X}
            y1={ZONE_BASELINE_Y}
            y2={ZONE_BASELINE_Y}
            stroke="var(--color-hairline)"
            stroke-width="1"
            aria-hidden="true"
          />
          {ZONE_BOUNDARY_PCTS.map((pct) => {
            const x = PAD_X + (pct / 100) * USABLE_W;
            return (
              <line
                class="winding-path-zone-line"
                x1={x}
                x2={x}
                y1={ZONE_TICK_TOP_Y}
                y2={ZONE_BASELINE_Y}
                stroke="var(--color-hairline)"
                stroke-width="1"
                aria-hidden="true"
              />
            );
          })}
        </g>

        <g data-layer="knockouts" />

        <g data-layer="markers">
          <circle cx={todayX} cy={todayY} r="9" fill="var(--winding-path-surface)" />
          <circle
            cx={todayX}
            cy={todayY}
            r="7"
            fill="white"
            stroke="var(--color-primary)"
            stroke-width="2"
          />
          {renderedEvents.map((ev) => (
            <>
              <circle cx={ev.x} cy={ev.y} r="11" fill="var(--winding-path-surface)" />
              <circle cx={ev.x} cy={ev.y} r="7" fill="var(--color-primary)" />
            </>
          ))}
        </g>

        <g data-layer="labels">
          {ZONES.map((zone) => {
            const x = PAD_X + (zone.centerPct / 100) * USABLE_W;
            return (
              <text
                class="winding-path-zone"
                data-knockout
                x={x}
                y={ZONE_LABEL_Y}
                font-size="9"
                font-weight="700"
                text-anchor="middle"
                fill="var(--color-body)"
              >
                {zone.label}
              </text>
            );
          })}

          <text
            data-knockout
            x={todayX}
            y={todayY + todayMainDy}
            font-size="11"
            font-weight="700"
            text-anchor="middle"
            fill="var(--color-primary)"
          >
            Today
          </text>

          {renderedEvents.map((ev) => (
            <>
              <text
                data-knockout
                x={ev.x}
                y={ev.y + ev.mainDy}
                font-size="11"
                font-weight="700"
                text-anchor="middle"
                fill="var(--color-primary-deep, var(--color-primary))"
              >
                {ev.label}
              </text>
              {ev.sub && (
                <text
                  data-knockout
                  x={ev.x}
                  y={ev.y + ev.subDy}
                  font-size="9.5"
                  font-weight="400"
                  text-anchor="middle"
                  fill="var(--color-body)"
                >
                  {ev.sub}
                </text>
              )}
            </>
          ))}
        </g>
      </svg>
    ) : (
      <p class="winding-path-varies">Wait time varies by service.</p>
    )}
  </div>
</div>

<script>
  document.querySelectorAll('svg.winding-path').forEach((svg) => {
    const knockoutLayer = svg.querySelector('g[data-layer="knockouts"]');
    const labelsLayer = svg.querySelector('g[data-layer="labels"]');

    if (!knockoutLayer || !labelsLayer) return;

    knockoutLayer.querySelectorAll('rect[data-knockout-bg]').forEach((rect) => rect.remove());

    labelsLayer.querySelectorAll<SVGTextElement>('text[data-knockout]').forEach((t) => {
      const bb = t.getBBox();
      const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
      rect.setAttribute('x', String(bb.x - 3));
      rect.setAttribute('y', String(bb.y - 1));
      rect.setAttribute('width', String(bb.width + 6));
      rect.setAttribute('height', String(bb.height + 2));
      rect.setAttribute('rx', '2');
      rect.setAttribute('fill', 'var(--winding-path-surface)');
      rect.setAttribute('data-knockout-bg', '');
      knockoutLayer.appendChild(rect);
    });
  });
</script>

<style>
  .winding-path-wrap {
    /* Panel surface, referenced by the SVG halo circles and JS-built label
       knockout rects so they always match the background exactly. */
    --winding-path-surface: var(--color-page-sage);
    background: var(--winding-path-surface);
    padding: 22px 22px 14px;
    border-radius: 14px;
    flex-basis: 100%;
  }
  .winding-path-inner {
    /* Caps the graphic's width; the SVG is width:100%/height:auto over a fixed
       viewBox, so height follows in proportion. min(100%, …) means narrow
       screens resolve to 100% and never reach the cap — lowering it scales the
       graphic down on desktop only, no media query needed. */
    width: min(100%, 22rem);
    margin-inline: auto;
  }
  .winding-path-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-meta-sage);
    text-transform: uppercase;
    margin-bottom: 6px;
    text-align: center;
  }
  .winding-path {
    width: 100%;
    height: auto;
    display: block;
  }
  .winding-path text {
    font-family: var(--font-sans, ui-sans-serif, system-ui);
  }
  .winding-path-varies {
    font-size: 13px;
    color: var(--color-body);
    margin: 8px 0 0;
    text-align: center;
  }

  /* Desktop opens the steps list below this panel, so the open card is fighting
     for vertical room; trim the panel's own padding there. */
  @media (min-width: 768px) {
    .winding-path-wrap {
      padding: 16px 22px 12px;
    }
  }

  @media (max-width: 359px) {
    .winding-path-zone,
    .winding-path-zone-line {
      display: none;
    }
  }
</style>
