---
const year = new Date().getFullYear();
---
<footer class="bg-paper-cream border-t border-pencil">
  <div class="max-w-6xl mx-auto px-4 py-16">
    <div class="grid md:grid-cols-4 gap-10 text-sm text-body">
      <div>
        <a href="/" class="text-lg font-bold text-heading mb-3 inline-block">
          HealthMaps
        </a>
        <p class="text-body">Helping Australians navigate the mental health system with clear, practical information.</p>
      </div>
      <div>
        <h3 class="font-semibold text-heading mb-3">Quick Links</h3>
        <ul class="space-y-2">
          <li><a href="/pathway/" class="hover:text-primary transition-colors">Getting Started</a></li>
          <li><a href="/practitioners/" class="hover:text-primary transition-colors">Types of Professionals</a></li>
          <li><a href="/calculator/" class="hover:text-primary transition-colors">Cost Calculator</a></li>
        </ul>
      </div>
      <div>
        <h3 class="font-semibold text-heading mb-3">About</h3>
        <ul class="space-y-2">
          <li><a href="/about/" class="hover:text-primary transition-colors">About HealthMaps</a></li>
          <li><a href="/disclaimer/" class="hover:text-primary transition-colors">Disclaimer</a></li>
          <li><a href="/privacy/" class="hover:text-primary transition-colors">Privacy</a></li>
          <li><a href="mailto:jethrohedstrom@gmail.com" class="hover:text-primary transition-colors">Contact</a></li>
        </ul>
      </div>
      <div>
        <h3 class="font-semibold text-heading mb-3">Crisis Support</h3>
        <ul class="space-y-2">
          <li><a href="tel:131114" class="hover:text-primary transition-colors">Lifeline: 13 11 14</a></li>
          <li><a href="tel:1300224636" class="hover:text-primary transition-colors">Beyond Blue: 1300 22 4636</a></li>
          <li><a href="tel:000" class="hover:text-primary transition-colors font-semibold">Emergency: 000</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-12 pt-8 border-t border-border text-xs text-body text-center">
      <p>&copy; {year} HealthMaps. This site provides general information only and is not a substitute for professional medical advice.</p>
    </div>
  </div>
</footer>
