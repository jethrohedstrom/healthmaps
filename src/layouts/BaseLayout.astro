---
import '../styles/global.css';
import CrisisBanner from '../components/CrisisBanner.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollProgress from '../components/ScrollProgress.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  hideCrisisPill?: boolean;
  noindex?: boolean;
}

const {
  title,
  description = 'Navigate Australia\'s mental health system with clear, step-by-step guidance. Find the right practitioner, understand costs, and access Medicare rebates.',
  ogImage = '/og-default.png',
  hideCrisisPill = false,
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://healthmaps.com.au');
const ogImageURL = new URL(ogImage, Astro.site ?? 'https://healthmaps.com.au');
---
<!DOCTYPE html>
<html lang="en-AU">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | HealthMaps</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <!-- Tints mobile browser chrome to match the header; keep in sync with --color-paper-cream in global.css -->
    <meta name="theme-color" content="#FBFAF6" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | HealthMaps`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content="en_AU" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | HealthMaps`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Preload fonts (high priority, avoids FOUT) -->
    <link rel="preload" href="/fonts/Switzer-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/GeneralSans-Variable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Favicon — ?v=2 busts Chrome's cached copy of the original Astro icon -->
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="min-h-screen flex flex-col bg-page-sage">
    <ScrollProgress />
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />

    {!hideCrisisPill && <CrisisBanner />}
  </body>
</html>
