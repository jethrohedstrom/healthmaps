---
import BaseLayout from '../layouts/BaseLayout.astro';
import MetroMap from '../components/MetroMap.astro';
---
<BaseLayout
  title="Experimental — Visual Overview"
  description="Experimental visual overview of the pathway page. Not linked from nav."
  hideCrisisPill={true}
>
  <!-- Experimental note -->
  <section class="bg-white">
    <div class="max-w-[960px] mx-auto px-4 pt-10 pb-2">
      <div class="rounded-xl border border-border bg-bg-light px-4 py-3 text-sm text-body">
        <span class="font-semibold text-heading">Experimental</span> — not linked from nav.
      </div>
    </div>
  </section>

  <!-- Metro Map (visual overview) -->
  <section class="bg-bg-light">
    <div class="max-w-[960px] mx-auto px-4 py-16 md:py-20">
      <p class="uppercase tracking-widest text-sm text-primary mb-3 font-semibold">Visual overview</p>
      <h2 class="text-xl font-bold text-heading mb-2">Prefer a visual overview?</h2>
      <p class="text-body mb-10">The same pathways shown as a route map.</p>
      <MetroMap />
    </div>
  </section>

</BaseLayout>
