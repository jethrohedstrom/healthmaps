---
import BaseLayout from '../layouts/BaseLayout.astro';
import MetroMap from '../components/MetroMap.astro';
---
<BaseLayout
  title="Pathway visual overview (experimental)"
  description="A visual map of the five routes to mental health support in Australia — through your GP, privately, or via free options."
  noindex={true}
>
  <!-- Hero -->
  <section class="bg-white">
    <div class="max-w-[720px] mx-auto px-4 py-12 md:py-16">
      <div class="rounded-xl border border-border bg-bg-light px-4 py-3 text-sm text-body mb-8">
        <span class="font-semibold text-heading">Experimental</span> — not linked from nav.
      </div>
      <h1 class="text-3xl md:text-[2.5rem] font-bold text-heading mb-4 tracking-[-0.01em]">Pathway visual overview</h1>
      <p class="text-lg leading-relaxed text-body">
        Mental health support pathways shown as a route map.
      </p>
    </div>
  </section>

  <!-- Metro Map -->
  <section class="bg-bg-light">
    <div class="max-w-[960px] mx-auto px-4 py-16 md:py-20">
      <MetroMap />
    </div>
  </section>
</BaseLayout>
