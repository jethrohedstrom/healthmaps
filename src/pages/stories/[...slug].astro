---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const stories = await getCollection('stories');
  return stories.map(story => ({
    params: { slug: story.id },
    props: { story },
  }));
}

const { story } = Astro.props;
const { Content } = await render(story);
---
<BaseLayout
  title={story.data.title}
  description={story.data.summary}
>
  <article class="max-w-body mx-auto px-4 py-16 md:py-20">
    <a href="/stories/" class="text-sm text-body hover:text-primary transition-colors mb-6 inline-block">&larr; All stories</a>
    <h1 class="text-3xl md:text-[2.25rem] font-bold text-heading mb-2 tracking-[-0.01em]">"{story.data.title}"</h1>
    <p class="text-body mb-8">
      {story.data.name}{story.data.age ? `, ${story.data.age}` : ''}{story.data.location ? `, ${story.data.location}` : ''}
    </p>
    {/* Remove this note once real, consented stories replace the composites */}
    <p class="text-sm text-body bg-bg-light rounded-lg px-5 py-3 mb-8">
      This is an illustrative story based on common experiences, not a real person's account.
    </p>
    <div class="prose max-w-none text-body">
      <Content />
    </div>
    <div class="mt-16 pt-8 border-t border-border text-center">
      <Button href="/pathway/" size="lg">Get Started with Your Own Plan</Button>
    </div>
  </article>
</BaseLayout>
