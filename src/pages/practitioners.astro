---
import BaseLayout from '../layouts/BaseLayout.astro';
import PractitionerBubbleMap from '../components/PractitionerBubbleMap.astro';
import MHCPInline from '../components/MHCPInline.astro';
---
<BaseLayout
  title="Who should I see?"
  description="Compare mental health professionals in Australia, including psychologists, psychiatrists, counsellors, social workers, and more. Understand costs, Medicare rebates, and referral requirements."
>
  <!-- Hero + bubble map -->
  <section class="bg-white">
    <div class="max-w-[1100px] mx-auto px-4 pt-10 md:pt-20 pb-8 md:pb-10">
      <h1 class="text-3xl md:text-[2.5rem] font-bold text-heading mb-2 tracking-[-0.01em] text-center">Who should I see?</h1>
      <PractitionerBubbleMap />
    </div>
  </section>

  <!-- "Does it actually matter?" accordion -->
  <section class="bg-white">
    <div class="max-w-[960px] mx-auto px-4 pt-2 pb-16 md:pb-20 flex justify-center">
      <details id="hero-accordion" class="accordion-item scroll-mt-24 bg-bg-light rounded-lg px-6 md:px-10 py-4">
        <summary class="text-lg font-semibold text-heading w-fit mx-auto">Does it actually matter?</summary>
        <div class="accordion-content space-y-5 text-lg leading-relaxed text-body mt-4">
          <p>For many people, the title and training of the professional (i.e. counsellor, psychologist, psychotherapist) matters less than the sense that they trust and get along with their professional.</p>
          <p>But there are times when it really does matter.<br />For example, the term 'psychotherapist' is unregulated in Australia, meaning anyone can use it.<br />And only medical doctors, like General Practitioners (GPs) and psychiatrists, can prescribe medication.</p>
        </div>
      </details>
    </div>
  </section>

  <!-- GP callout -->
  <section class="bg-white">
    <div class="max-w-[960px] mx-auto px-4 pb-10 md:pb-12">
      <div class="bg-primary-light rounded-xl p-8 md:p-10">
        <div class="flex flex-col md:flex-row md:items-start gap-4">
          <div class="w-10 h-10 rounded-lg bg-white flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-heading mb-2">Not sure where to start? See your GP.</h3>
            <p class="text-body text-sm leading-relaxed">
              Your GP can assess your situation, create a <MHCPInline />, and refer you to the right professional. This is the most common first step, and it unlocks Medicare rebates.
            </p>
            <div class="gp-callout-buttons flex flex-col sm:flex-row gap-3 mt-4">
              <a
                href="/pathway/"
                class="inline-flex items-center justify-center gap-1.5 text-sm font-semibold text-heading bg-white border border-border px-5 py-2.5 rounded-lg hover:border-primary hover:text-primary transition-colors"
              >
                What is a GP?
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
              </a>
              <a
                href="https://www.healthdirect.gov.au/australian-health-services"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-1.5 text-sm font-semibold text-heading bg-white border border-border px-5 py-2.5 rounded-lg hover:border-primary hover:text-primary transition-colors"
              >
                I don't have a GP
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-bg-light">
    <div class="max-w-[720px] mx-auto px-4 py-16 md:py-20 text-center">
      <h2 class="text-xl font-semibold text-heading mb-3">Want to estimate your out-of-pocket costs?</h2>
      <a href="/calculator/" class="inline-block bg-primary text-white px-10 py-4 rounded-xl font-semibold shadow-sm hover:bg-primary/90 transition-colors">
        Use the Cost Calculator
      </a>
    </div>
  </section>

  <!-- Auto-open accordion when navigating from decision helper -->
  <script>
    let suppressNextScroll = false;
    const debugRunId = `run-${Date.now()}`;
    function debugLog(hypothesisId: string, location: string, message: string, data: Record<string, unknown>) {
      fetch('http://127.0.0.1:7840/ingest/4796b335-cf3c-4958-9a7c-6583e2dcb00e',{method:'POST',headers:{'Content-Type':'application/json','X-Debug-Session-Id':'a57960'},body:JSON.stringify({sessionId:'a57960',runId:debugRunId,hypothesisId,location,message,data,timestamp:Date.now()})}).catch(()=>{});
    }
    // #region agent log
    debugLog('P1', 'src/pages/practitioners.astro:scriptInit', 'practitioners inline script init', {
      hash: window.location.hash,
      scrollY: window.scrollY,
      scrollRestoration: history.scrollRestoration
    });
    // #endregion
    window.addEventListener('pageshow', (e) => {
      // #region agent log
      debugLog('P1', 'src/pages/practitioners.astro:pageshow', 'pageshow fired', {
        persisted: e.persisted,
        scrollY: window.scrollY,
        hash: window.location.hash
      });
      // #endregion
    });

    function openTargetAccordion() {
      const hash = window.location.hash;
      // #region agent log
      debugLog('P3', 'src/pages/practitioners.astro:openTargetAccordion:start', 'openTargetAccordion invoked', {
        hash,
        scrollY: window.scrollY
      });
      // #endregion
      if (!hash) return;
      const target = document.querySelector(hash);
      if (target instanceof HTMLDetailsElement) {
        let ancestor = target.parentElement;
        while (ancestor) {
          if (ancestor instanceof HTMLDetailsElement) {
            ancestor.open = true;
          }
          ancestor = ancestor.parentElement;
        }
        if (!target.open) {
          suppressNextScroll = true;
          target.open = true;
        }
        // #region agent log
        debugLog('P3', 'src/pages/practitioners.astro:openTargetAccordion:end', 'openTargetAccordion finished target handling', {
          hash,
          suppressNextScroll,
          targetOpen: target.open,
          scrollY: window.scrollY
        });
        // #endregion
      }
    }
    openTargetAccordion();
    window.addEventListener('hashchange', openTargetAccordion);

    const heroAccordionEl = document.getElementById('hero-accordion');
    if (heroAccordionEl instanceof HTMLDetailsElement) {
      const prevBindCount = Number(heroAccordionEl.dataset.debugToggleBindCount || '0');
      heroAccordionEl.dataset.debugToggleBindCount = String(prevBindCount + 1);
      // #region agent log
      debugLog('P5', 'src/pages/practitioners.astro:heroAccordion:bind', 'hero accordion toggle listener bound', {
        prevBindCount,
        currentBindCount: prevBindCount + 1,
        initiallyOpen: heroAccordionEl.open,
        scrollY: window.scrollY
      });
      // #endregion
      heroAccordionEl.addEventListener('toggle', () => {
        // #region agent log
        debugLog('P2', 'src/pages/practitioners.astro:heroAccordion:toggle', 'hero accordion toggled', {
          open: heroAccordionEl.open,
          suppressNextScroll,
          scrollY: window.scrollY
        });
        // #endregion
        if (heroAccordionEl.open) {
          if (suppressNextScroll) {
            suppressNextScroll = false;
            // #region agent log
            debugLog('P2', 'src/pages/practitioners.astro:heroAccordion:toggleSuppressed', 'scroll suppressed after toggle', {
              open: heroAccordionEl.open,
              scrollY: window.scrollY
            });
            // #endregion
            return;
          }
          requestAnimationFrame(() => {
            // #region agent log
            debugLog('P2', 'src/pages/practitioners.astro:heroAccordion:beforeScrollIntoView', 'about to call scrollIntoView', {
              open: heroAccordionEl.open,
              scrollY: window.scrollY
            });
            // #endregion
            heroAccordionEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
            // #region agent log
            debugLog('P2', 'src/pages/practitioners.astro:heroAccordion:afterScrollIntoView', 'scrollIntoView called', {
              open: heroAccordionEl.open,
              scrollY: window.scrollY
            });
            // #endregion
          });
        }
      });

      const content = heroAccordionEl.querySelector('.accordion-content');
      if (content instanceof HTMLElement) {
        content.addEventListener('click', () => {
          const selection = window.getSelection();
          if (selection && selection.toString().length > 0) return;
          heroAccordionEl.open = false;
        });
      }
    }

  </script>
</BaseLayout>
