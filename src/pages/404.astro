---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---
<BaseLayout title="Page Not Found">
  <section class="max-w-body mx-auto px-4 py-24 md:py-40 text-center">
    <h1 class="text-6xl font-bold text-heading mb-4">404</h1>
    <p class="text-xl text-body mb-8">Sorry, this page doesn't exist.</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <Button href="/" size="lg">Go Home</Button>
      <a href="/pathway/" class="bg-white text-heading border-2 border-border px-10 py-4 rounded-xl font-semibold hover:border-primary hover:text-primary transition-colors">
        Getting Started Guide
      </a>
    </div>
  </section>
</BaseLayout>
