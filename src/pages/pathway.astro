---
import BaseLayout from '../layouts/BaseLayout.astro';
import PathwayCardVisual from '../components/PathwayCardVisual.astro';
import JourneyStrip from '../components/JourneyStrip.astro';
import CrisisFooterBar from '../components/CrisisFooterBar.astro';
import MetroMap from '../components/MetroMap.astro';
import PathwayTree from '../components/PathwayTree.astro';
import { pathwayCards } from '../data/pathway-cards';

const crisisCard = pathwayCards.find(c => c.isCrisis)!;
const otherCards = pathwayCards.filter(c => !c.isCrisis);
---
<BaseLayout
  title="How to Access Mental Health Support"
  description="Six pathways to mental health support in Australia — crisis help, Medicare, private, low-cost, psychiatrist referral, and NDIS."
  hideCrisisPill={true}
>
  <!-- Hero -->
  <section class="bg-white">
    <div class="max-w-[720px] mx-auto px-4 py-16 md:py-20">
      <h1 class="text-3xl md:text-[2.5rem] font-bold text-heading mb-4 tracking-[-0.01em]">How to access mental health support in Australia</h1>
      <p class="text-lg leading-relaxed text-body">
        There are several ways to get mental health support. Here's how each one works — and what it costs.
      </p>
    </div>
  </section>

  {/* Quiz placeholder — commented out, preserved for later
  <section class="bg-bg-light">
    <div class="max-w-[720px] mx-auto px-4 py-12 md:py-16 text-center">
      <p class="text-lg font-semibold text-heading mb-4">Not sure where to start?</p>
      <button
        type="button"
        disabled
        class="inline-block bg-primary text-white px-10 py-4 rounded-xl font-semibold shadow-sm opacity-75 cursor-not-allowed"
      >
        Take the quiz (coming soon)
      </button>
    </div>
  </section>
  */}

  <!-- Pathway cards -->
  <section class="bg-white">
    <div class="max-w-[960px] mx-auto px-4 py-16 md:py-20 pb-28">
      <h2 class="text-xl font-bold text-heading mb-2">6 ways to access support</h2>
      <p class="text-body mb-10">Each pathway has different costs, wait times, and steps. Compare them below.</p>

      {/* Crisis card — full width, visually distinct */}
      <PathwayCardVisual {...crisisCard} />

      {/* Remaining cards — 2-col grid on desktop, 1-col on mobile */}
      <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-6">
        {otherCards.map((card) => (
          <PathwayCardVisual {...card} />
        ))}
      </div>
    </div>
  </section>

  <!-- Section divider -->
  <hr class="section-divider" />

  <!-- Variant B: Journey Strips -->
  <section class="bg-bg-light">
    <div class="max-w-[960px] mx-auto px-4 py-16 md:py-20">
      <p class="uppercase tracking-widest text-sm text-primary mb-3 font-semibold">Alternate view</p>
      <h2 class="text-xl font-bold text-heading mb-2">Compare the journey</h2>
      <p class="text-body mb-10">See how many steps each pathway takes. Tap a step to see what's involved.</p>

      <div class="space-y-6">
        {pathwayCards.map((card) => (
          <JourneyStrip {...card} />
        ))}
      </div>
    </div>
  </section>

  <!-- Section divider -->
  <hr class="section-divider" />

  <!-- Variant C: Metro Map -->
  <section class="bg-white">
    <div class="max-w-[960px] mx-auto px-4 py-16 md:py-20">
      <p class="uppercase tracking-widest text-sm text-primary mb-3 font-semibold">Visual overview</p>
      <h2 class="text-xl font-bold text-heading mb-2">See the routes at a glance</h2>
      <p class="text-body mb-10">Five routes to professional mental health support in Australia.</p>
      <MetroMap />
    </div>
  </section>

  <!-- Section divider -->
  <hr class="section-divider" />

  <!-- Variant D: Branching tree -->
  <section class="bg-bg-light">
    <div class="max-w-[960px] mx-auto px-4 py-16 md:py-20">
      <p class="uppercase tracking-widest text-sm text-primary mb-3 font-semibold">Minimal tree</p>
      <h2 class="text-xl font-bold text-heading mb-2">Where to start</h2>
      <p class="text-body mb-10">Four ways in. Tap "Through your GP" to see the specialist routes that branch from there.</p>
      <PathwayTree />
    </div>
  </section>

  <CrisisFooterBar />
</BaseLayout>
