---
import BaseLayout from '../layouts/BaseLayout.astro';
import PathwayCardVisual from '../components/PathwayCardVisual.astro';
import PathwayCardGPProgressive from '../components/PathwayCardGPProgressive.astro';
import { pathwayCards } from '../data/pathway-cards';

const gpCard = pathwayCards.find((c) => c.id === 'through-gp')!;
const otherCards = pathwayCards.filter((c) => c.id !== 'through-gp');
---
<BaseLayout
  title="How to Access Mental Health Support"
  description="Ways to access mental health support in Australia: through your GP, privately, free or low-cost services, and digital programs."
>
  <section>
    <div class="max-w-[1240px] mx-auto px-4 md:px-6 pt-8 md:pt-20 pb-10 md:pb-16">
      <div class="bg-paper-cream border border-[color:var(--color-paper-border)] rounded-3xl shadow-[0_30px_70px_-40px_rgba(15,74,50,0.18)] px-6 md:px-14 py-10 md:py-14">
        <div class="pathway-hero-grid grid grid-cols-1 lg:grid-cols-[1.05fr_1fr] gap-10 lg:gap-14 items-start">
        <div class="pathway-hero-aside">
          <div class="inline-flex items-center gap-2 mb-4 text-xs font-bold uppercase tracking-[0.14em] text-primary">
            <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
            Getting started
          </div>
          <h1 class="text-[1.75rem] md:text-[2.5rem] font-bold text-heading mb-4 tracking-[-0.01em] leading-tight">How to access mental health support in Australia</h1>
          <p class="text-lg leading-relaxed text-body max-w-[42rem] mb-6">
            There are several ways to get support. Most people start with their GP, but you don't have to.
          </p>
          <div class="flex flex-wrap gap-3">
            <a
              href="#pathways"
              class="bg-primary text-white px-5 py-3 rounded-xl font-semibold text-sm hover:bg-primary-mid transition-colors"
            >
              Compare all 5 pathways
            </a>
            <button
              type="button"
              disabled
              class="border border-border text-heading px-5 py-3 rounded-xl font-semibold text-sm opacity-75 cursor-not-allowed"
            >
              Not sure? Take the quiz
            </button>
          </div>
        </div>

          <div class="relative">
            <PathwayCardGPProgressive {...gpCard} />
            <div class="mt-3 flex justify-end">
              <a
                href="#pathways"
                class="inline-flex items-center gap-1.5 text-sm font-medium text-body/70 hover:text-primary transition-colors"
              >
                <span>4 more pathways below</span>
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="pathways" class="scroll-mt-24">
    <div class="max-w-[1240px] mx-auto px-4 md:px-6 py-12 md:py-16">
      <p class="text-sm uppercase tracking-widest text-body font-semibold mb-6">The other 4 pathways</p>

      <div class="pathway-grid grid grid-cols-1 md:grid-cols-2 gap-6 items-stretch">
        {otherCards.map((card) => (
          <PathwayCardVisual {...card} />
        ))}
      </div>

      <aside class="mt-8 max-w-3xl mx-auto rounded-xl border border-[color:var(--color-paper-border)] bg-paper-cream p-6 md:p-8 shadow-sm">
        <p class="uppercase tracking-widest text-xs text-primary mb-2 font-semibold">Also worth knowing</p>
        <h3 class="text-lg font-bold text-heading mb-2">NDIS-funded mental health support</h3>
        <p class="text-body leading-relaxed">
          If you have a severe, long-term mental health condition (psychosocial disability) that substantially affects your daily life, you may be eligible for NDIS-funded support.
          <a href="/ndis" class="text-primary font-semibold underline underline-offset-2">Learn about the NDIS pathway</a>.
        </p>
      </aside>
    </div>
  </section>

  {/* Quiz placeholder: commented out, preserved for later
  <section class="bg-bg-light">
    <div class="max-w-[720px] mx-auto px-4 py-12 md:py-16 text-center">
      <p class="text-lg font-semibold text-heading mb-4">Not sure where to start?</p>
      <button
        type="button"
        disabled
        class="inline-block bg-primary text-white px-10 py-4 rounded-xl font-semibold shadow-sm opacity-75 cursor-not-allowed"
      >
        Take the quiz (coming soon)
      </button>
    </div>
  </section>
  */}

  <script>
    import '../scripts/pathway-card-click.ts';
  </script>

</BaseLayout>
