---
import BaseLayout from '../layouts/BaseLayout.astro';
import PathwayCardVisual from '../components/PathwayCardVisual.astro';
import { pathwayCards } from '../data/pathway-cards';

---
<BaseLayout
  title="How to Access Mental Health Support"
  description="Ways to access mental health support in Australia: through your GP, privately, free or low-cost services, and digital programs."
  hideCrisisPill={true}
>
  <!-- Hero -->
  <section class="bg-white">
    <div class="max-w-[720px] mx-auto px-4 py-16 md:py-20">
      <h1 class="text-3xl md:text-[2.5rem] font-bold text-heading mb-4 tracking-[-0.01em]">How to access mental health support in Australia</h1>
      <p class="text-lg leading-relaxed text-body">
        There are several ways to get mental health support. Here's how each one works, and what it costs.
      </p>
    </div>
  </section>

  <!-- Crisis signpost -->
  <section class="bg-white">
    <div class="max-w-[960px] mx-auto px-4">
      <div class="max-w-xs mx-auto rounded-xl shadow-sm border-2 border-accent-red bg-accent-red-light px-4 py-3 text-center">
        <div class="w-10 h-10 bg-accent-red-light rounded-xl flex items-center justify-center mx-auto mb-3">
          <svg class="w-5 h-5 text-accent-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
          </svg>
        </div>
        <h2 class="text-lg font-bold text-heading mb-1">In crisis or need help now?</h2>
        <p class="text-sm text-body mb-1">
          Emergency <a href="tel:000" class="font-semibold text-heading underline underline-offset-2">000</a>
          &nbsp;&middot;&nbsp;
          Lifeline <a href="tel:131114" class="font-semibold text-heading underline underline-offset-2">13 11 14</a>
        </p>
        <p class="text-xs text-body/80">Free, 24/7</p>
      </div>
    </div>
  </section>

  {/* Quiz placeholder: commented out, preserved for later
  <section class="bg-bg-light">
    <div class="max-w-[720px] mx-auto px-4 py-12 md:py-16 text-center">
      <p class="text-lg font-semibold text-heading mb-4">Not sure where to start?</p>
      <button
        type="button"
        disabled
        class="inline-block bg-primary text-white px-10 py-4 rounded-xl font-semibold shadow-sm opacity-75 cursor-not-allowed"
      >
        Take the quiz (coming soon)
      </button>
    </div>
  </section>
  */}

  <!-- Pathway cards -->
  <section class="bg-white">
    <div class="max-w-[960px] mx-auto px-4 py-16 md:py-20">
      <h2 class="text-xl font-bold text-heading mb-2">Ways to access support</h2>
      <p class="text-body mb-10">Each pathway has different costs, wait times, and steps. Compare them below.</p>

      <div class="bg-primary-light rounded-2xl p-6 md:p-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-stretch">
          {pathwayCards.map((card) => (
            <PathwayCardVisual {...card} />
          ))}
        </div>
      </div>

      <aside class="mt-10 max-w-3xl rounded-xl border border-border bg-bg-light p-6 md:p-8">
        <p class="uppercase tracking-widest text-xs text-primary mb-2 font-semibold">Also worth knowing</p>
        <h3 class="text-lg font-bold text-heading mb-2">NDIS-funded mental health support</h3>
        <p class="text-body leading-relaxed">
          If you have a severe, long-term mental health condition (psychosocial disability) that substantially affects your daily life, you may be eligible for NDIS-funded support.
          <a href="/ndis" class="text-primary font-semibold underline underline-offset-2">Learn about the NDIS pathway</a>.
        </p>
      </aside>
    </div>
  </section>

</BaseLayout>
