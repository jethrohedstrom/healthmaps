---
import BaseLayout from '../layouts/BaseLayout.astro';
import PathwayQuiz from '../components/PathwayQuiz.astro';
import PathwayCardVisual from '../components/PathwayCardVisual.astro';
import WayRow, { type Props as WayRowProps } from '../components/WayRow.astro';
import { pathwayCards } from '../data/pathway-cards';

const liveCards = pathwayCards.filter((c) => !c.draft);

// "All the ways" row copy is final design copy (handoff 6a) and intentionally
// diverges from the detailed cards' titles in pathway-cards.ts. Each row is
// keyed by its card's id and anchor-links to that card's detail below.
const ways: ({ id: string } & Omit<WayRowProps, 'href'>)[] = [
  {
    id: 'through-gp',
    title: 'Start with a GP',
    body: 'A GP can listen, help you make sense of things, and refer you on. Medicare rebates apply.',
    icon: 'gp',
    kicker: 'Most people start here',
    featured: true,
  },
  {
    id: 'private',
    title: 'Go straight to a practitioner',
    body: 'Ready to see someone? Book a psychologist or counsellor directly.',
    icon: 'practitioner',
  },
  {
    id: 'low-cost',
    title: 'Community & public services',
    body: 'Free and lower-cost help near you, through local and state-funded services.',
    icon: 'community',
  },
  {
    id: 'self-guided',
    title: 'Try something self-guided',
    body: 'Free online programs you can start tonight, in your own time.',
    icon: 'self-guided',
  },
];

// Fail the build if a row points at a card that no longer exists.
for (const way of ways) {
  if (!liveCards.some((c) => c.id === way.id)) {
    throw new Error(`pathway.astro: way row "${way.title}" targets unknown pathway card id "${way.id}"`);
  }
}
---
<BaseLayout
  title="How to Access Mental Health Support"
  description="Ways to start with mental health support in Australia: through your GP, a private practitioner, a free or community service, self-guided tools, or crisis support."
>
  <!-- Hero: quiz-forward, on the sage page background -->
  <section class="px-5 md:px-14 py-16 md:py-20">
    <div class="max-w-[680px] mx-auto text-center">
      <h1 class="font-bold text-[1.875rem] md:text-[3.125rem] tracking-[-0.025em] leading-[1.06] text-heading">
        Mental health support in Australia: where to begin
      </h1>
      <div class="mt-8 md:mt-11">
        <PathwayQuiz />
      </div>
    </div>
  </section>

  <section id="all-the-ways" class="scroll-mt-24 bg-paper-cream px-5 md:px-14">
    <div class="max-w-[900px] mx-auto pt-16 md:pt-[76px] pb-16 md:pb-[84px]">
      <!-- Wobble filters for the WayRow icons (referenced by id, defined once per page) -->
      <svg width="0" height="0" class="absolute" aria-hidden="true"><defs>
        <filter id="paint-a" x="-60%" y="-60%" width="220%" height="220%" color-interpolation-filters="sRGB"><feTurbulence type="fractalNoise" baseFrequency="0.115" numOctaves="3" seed="4" result="n"></feTurbulence><feDisplacementMap in="SourceGraphic" in2="n" scale="3.2" xChannelSelector="R" yChannelSelector="G"></feDisplacementMap></filter>
        <filter id="paint-b" x="-60%" y="-60%" width="220%" height="220%" color-interpolation-filters="sRGB"><feTurbulence type="fractalNoise" baseFrequency="0.11" numOctaves="2" seed="11" result="n"></feTurbulence><feDisplacementMap in="SourceGraphic" in2="n" scale="2.4" xChannelSelector="R" yChannelSelector="G"></feDisplacementMap></filter>
        <filter id="paint-c" x="-60%" y="-60%" width="220%" height="220%" color-interpolation-filters="sRGB"><feTurbulence type="fractalNoise" baseFrequency="0.1" numOctaves="2" seed="19" result="n"></feTurbulence><feDisplacementMap in="SourceGraphic" in2="n" scale="2.1" xChannelSelector="R" yChannelSelector="G"></feDisplacementMap></filter>
      </defs></svg>

      <p class="text-[13px] font-semibold uppercase tracking-[0.13em] text-primary">Or choose for yourself</p>
      <h2 class="font-display font-semibold text-[28px] md:text-[34px] tracking-[-0.02em] text-heading mt-3">All the ways</h2>
      <p class="text-lg leading-[1.55] text-body max-w-[560px] mt-3">
        Every option leads somewhere good. Most people begin with a GP &mdash; but you don&rsquo;t have to.
      </p>

      <div class="mt-10 flex flex-col gap-2">
        {ways.map(({ id, ...way }) => (
          <WayRow href={`#${id}`} {...way} />
        ))}
      </div>
    </div>
  </section>

  <section id="pathways" class="scroll-mt-24">
    <div class="max-w-[1240px] mx-auto px-5 md:px-10 lg:px-14 py-16 md:py-24">
      <div class="max-w-card mx-auto mb-8">
        <p class="text-sm uppercase tracking-widest text-body font-semibold mb-3">In detail</p>
        <h2 class="font-display font-bold text-2xl md:text-3xl text-heading">How each way works</h2>
      </div>

      <div class="pathway-grid flex flex-col gap-6 lg:gap-8 max-w-card mx-auto">
        {liveCards.map((card) => (
          <PathwayCardVisual {...card} />
        ))}
      </div>

      <!-- REVIEW: Crisis section copy mirrors verified crisis support content from src/content/alternatives/crisis.md. -->
      <section id="crisis" tabindex="-1" class="scroll-mt-24 mt-6 lg:mt-8 max-w-card mx-auto rounded-xl border border-accent-red/20 border-l-4 border-l-accent-red bg-accent-red-light p-6 md:p-8 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-widest text-accent-red mb-2">Immediate help</p>
        <h2 class="text-xl md:text-2xl font-bold text-heading leading-snug mb-3">Crisis support</h2>
        <p class="text-base leading-relaxed text-body mb-5">
          If you or someone else is in immediate danger, call <a href="tel:000" class="text-primary font-semibold underline underline-offset-2">000</a>. If you need to talk to someone now, these services are free and confidential.
        </p>
        <div class="grid gap-3 md:grid-cols-2">
          <a href="tel:131114" class="rounded-lg bg-white px-4 py-3 text-heading font-semibold border border-border hover:border-primary">
            Lifeline: 13 11 14
          </a>
          <a href="tel:1300224636" class="rounded-lg bg-white px-4 py-3 text-heading font-semibold border border-border hover:border-primary">
            Beyond Blue: 1300 22 4636
          </a>
          <a href="tel:1300659467" class="rounded-lg bg-white px-4 py-3 text-heading font-semibold border border-border hover:border-primary">
            Suicide Call Back Service: 1300 659 467
          </a>
          <a href="tel:139276" class="rounded-lg bg-white px-4 py-3 text-heading font-semibold border border-border hover:border-primary">
            13YARN: 13 92 76
          </a>
        </div>
      </section>

      <aside class="mt-8 max-w-3xl mx-auto rounded-xl bg-bg-light p-6 md:p-8">
        <p class="uppercase tracking-widest text-xs text-body mb-2 font-semibold">Also worth knowing</p>
        <h2 class="text-lg font-bold text-heading mb-2">NDIS-funded mental health support</h2>
        <p class="text-body leading-relaxed">
          If you have a severe, long-term mental health condition (psychosocial disability) that substantially affects your daily life, you may be eligible for NDIS-funded support.
          <a href="https://www.ndis.gov.au/understanding/how-ndis-works/mental-health-and-ndis" target="_blank" rel="noopener noreferrer" class="text-primary font-semibold underline underline-offset-2">Learn about NDIS mental health support</a>.
        </p>
      </aside>
    </div>
  </section>

  <script>
    import '../scripts/pathway-card-click.ts';
  </script>

</BaseLayout>
