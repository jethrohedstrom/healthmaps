---
import BaseLayout from '../layouts/BaseLayout.astro';
import PathwayQuiz from '../components/PathwayQuiz.astro';
import WayRow, { type Props as WayRowProps } from '../components/WayRow.astro';
import { pathwayCards } from '../data/pathway-cards';

const liveCards = pathwayCards.filter((c) => !c.draft);

// "All the ways" row copy is final design copy (handoff 6a) and intentionally
// diverges from the card titles in pathway-cards.ts. Each row is keyed by its
// card's id; the card's detail content expands in place inside the row.
const ways: ({ id: string } & Omit<WayRowProps, 'card'>)[] = [
  {
    id: 'through-gp',
    title: 'Start with a GP',
    body: 'A GP can listen, help you make sense of things, and refer you on. Medicare rebates apply.',
    icon: 'gp',
    kicker: 'Most people start here',
    featured: true,
  },
  {
    id: 'private',
    title: 'Go straight to a practitioner',
    body: 'Ready to see someone? Book a psychologist or counsellor directly.',
    icon: 'practitioner',
  },
  {
    id: 'low-cost',
    title: 'Community & public services',
    body: 'Free and lower-cost help near you, through local and state-funded services.',
    icon: 'community',
  },
  {
    id: 'self-guided',
    title: 'Try something self-guided',
    body: 'Free online programs you can start tonight, in your own time.',
    icon: 'self-guided',
  },
];

// Join rows to their card data; fail the build if a row points at a card
// that no longer exists.
const rows = ways.map(({ id, ...way }) => {
  const card = liveCards.find((c) => c.id === id);
  if (!card) {
    throw new Error(`pathway.astro: way row "${way.title}" targets unknown pathway card id "${id}"`);
  }
  return { ...way, card };
});

// Notes mirror the crisis modal in CrisisBanner.astro, except the Suicide Call
// Back Service line, which is new copy. <!-- REVIEW --> flagged in the markup.
const crisisLines = [
  { name: 'Lifeline', number: '13 11 14', tel: 'tel:131114', note: 'Anyone in crisis, 24/7' },
  { name: 'Beyond Blue', number: '1300 22 4636', tel: 'tel:1300224636', note: 'Depression and anxiety support, 24/7' },
  { name: 'Suicide Call Back Service', number: '1300 659 467', tel: 'tel:1300659467', note: "If you're having suicidal thoughts, or supporting someone who is, 24/7" },
  { name: '13YARN', number: '13 92 76', tel: 'tel:139276', note: 'For Aboriginal and Torres Strait Islander people, 24/7' },
];

// Same phone glyph as CrisisBanner.astro, so crisis rows read the same everywhere.
const phoneIconSvg = `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>`;
---
<BaseLayout
  title="How to Access Mental Health Support"
  description="Ways to start with mental health support in Australia: through your GP, a private practitioner, a free or community service, self-guided tools, or crisis support."
>
  <!-- Wobble filters for the way icons (referenced by id, defined once per page) -->
  <svg width="0" height="0" class="absolute" aria-hidden="true"><defs>
    <filter id="paint-a" x="-60%" y="-60%" width="220%" height="220%" color-interpolation-filters="sRGB"><feTurbulence type="fractalNoise" baseFrequency="0.115" numOctaves="3" seed="4" result="n"></feTurbulence><feDisplacementMap in="SourceGraphic" in2="n" scale="3.2" xChannelSelector="R" yChannelSelector="G"></feDisplacementMap></filter>
    <filter id="paint-b" x="-60%" y="-60%" width="220%" height="220%" color-interpolation-filters="sRGB"><feTurbulence type="fractalNoise" baseFrequency="0.11" numOctaves="2" seed="11" result="n"></feTurbulence><feDisplacementMap in="SourceGraphic" in2="n" scale="2.4" xChannelSelector="R" yChannelSelector="G"></feDisplacementMap></filter>
    <filter id="paint-c" x="-60%" y="-60%" width="220%" height="220%" color-interpolation-filters="sRGB"><feTurbulence type="fractalNoise" baseFrequency="0.1" numOctaves="2" seed="19" result="n"></feTurbulence><feDisplacementMap in="SourceGraphic" in2="n" scale="2.1" xChannelSelector="R" yChannelSelector="G"></feDisplacementMap></filter>
  </defs></svg>

  <!-- Hero: quiz-forward, on the sage page background -->
  <section class="px-5 md:px-14 py-16 md:py-20">
    <div class="max-w-[680px] mx-auto text-center">
      <h1 class="font-bold text-[1.875rem] md:text-[3.125rem] tracking-[-0.025em] leading-[1.06] text-heading">
        Mental health support in Australia: where to begin
      </h1>
      <div class="mt-8 md:mt-11">
        <PathwayQuiz />
      </div>
    </div>
  </section>

  <section id="all-the-ways" class="scroll-mt-24 bg-paper-cream px-5 md:px-14">
    <div class="max-w-[900px] mx-auto pt-16 md:pt-[76px] pb-16 md:pb-[84px]">
      <p class="text-[13px] font-semibold uppercase tracking-[0.13em] text-primary">Or choose for yourself</p>
      <h2 class="font-display font-semibold text-[28px] md:text-[34px] tracking-[-0.02em] text-heading mt-3">All the ways</h2>
      <p class="text-lg leading-[1.55] text-body max-w-[560px] mt-3">
        Every option leads somewhere good. Most people begin with a GP &mdash; but you don&rsquo;t have to. Open any option to see costs, timing, and how it works step by step.
      </p>

      <div class="mt-10 flex flex-col gap-2">
        {rows.map((row, index) => (
          <>
            <WayRow {...row} />
            {index < rows.length - 1 && (
              <!-- Route connector (echoes the quiz card motif): dots between stops.
                   md+ only — below md the featured tile centre sits 6px off the rest. -->
              <div class="hidden md:flex flex-col items-center gap-[5px] w-3 ml-[56px]" aria-hidden="true">
                <span class="w-1 h-1 rounded-full bg-primary opacity-35"></span>
                <span class="w-1 h-1 rounded-full bg-primary opacity-35"></span>
                <span class="w-1 h-1 rounded-full bg-primary opacity-35"></span>
              </div>
            )}
          </>
        ))}
      </div>
    </div>
  </section>

  <section class="px-5 md:px-14">
    <div class="max-w-[900px] mx-auto py-16 md:py-24">
      <!-- REVIEW: Crisis section copy mirrors verified crisis support content from src/content/alternatives/crisis.md
           and the CrisisBanner modal, except the Suicide Call Back Service note ("If you're having suicidal thoughts,
           or supporting someone who is, 24/7"), which is new AI-drafted copy. -->
      <section id="crisis" tabindex="-1" class="scroll-mt-24 rounded-[18px] bg-white border border-hairline p-6 md:p-8">
        <p class="text-[11.5px] font-semibold uppercase tracking-[0.08em] text-accent-red-soft mb-2">Immediate help</p>
        <h2 class="font-display font-semibold text-xl md:text-2xl tracking-[-0.01em] text-heading leading-snug mb-3">Crisis support</h2>
        <p class="text-base leading-relaxed text-body mb-5">
          If you need to talk to someone now, these services are free and confidential.
        </p>
        <div class="grid gap-3 md:grid-cols-2">
          <a href="tel:000" class="md:col-span-2 rounded-[12px] border border-hairline p-3.5 md:p-4 flex items-start gap-3.5 hover:border-accent-red-soft/40 hover:bg-accent-red-wash transition-colors duration-150">
            <span class="w-10 h-10 rounded-[10px] shrink-0 bg-accent-red-soft text-white inline-flex items-center justify-center" aria-hidden="true">
              <Fragment set:html={phoneIconSvg} />
            </span>
            <span class="min-w-0 flex-1">
              <span class="block font-semibold text-heading tabular-nums">Emergency &middot; 000</span>
              <span class="block text-sm text-body mt-0.5">If you or someone else is in immediate danger, 24/7</span>
            </span>
          </a>
          {crisisLines.map(({ name, number, tel, note }) => (
            <a href={tel} class="rounded-[12px] border border-hairline p-3.5 md:p-4 flex items-start gap-3.5 hover:border-accent-red-soft/40 hover:bg-accent-red-wash transition-colors duration-150">
              <span class="w-10 h-10 rounded-[10px] shrink-0 bg-accent-red-light text-accent-red-soft inline-flex items-center justify-center" aria-hidden="true">
                <Fragment set:html={phoneIconSvg} />
              </span>
              <span class="min-w-0 flex-1">
                <span class="block font-semibold text-heading tabular-nums">{name} &middot; {number}</span>
                <span class="block text-sm text-body mt-0.5">{note}</span>
              </span>
            </a>
          ))}
        </div>
      </section>

      <aside class="mt-8 rounded-[14px] bg-paper-cream border border-hairline p-6 md:p-8">
        <p class="text-[11.5px] font-semibold uppercase tracking-[0.08em] text-meta-sage mb-2">Also worth knowing</p>
        <h2 class="font-display font-semibold text-lg text-heading mb-2">NDIS-funded mental health support</h2>
        <p class="text-body leading-relaxed">
          If you have a severe, long-term mental health condition (psychosocial disability) that substantially affects your daily life, you may be eligible for NDIS-funded support.
          <a href="https://www.ndis.gov.au/understanding/how-ndis-works/mental-health-and-ndis" target="_blank" rel="noopener noreferrer" class="text-primary font-semibold underline underline-offset-2">Learn about NDIS mental health support</a>.
        </p>
      </aside>
    </div>
  </section>

</BaseLayout>
