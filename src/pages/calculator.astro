---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import CostCalculator from '../components/CostCalculator.astro';
import costs from '../data/calculator-costs.json';

const lastVerified = new Date(costs.lastUpdated).toLocaleDateString('en-AU', {
  month: 'long',
  year: 'numeric',
});
---
<BaseLayout
  title="Cost Calculator"
  description="Estimate what a psychology session costs out-of-pocket in Australia after the Medicare rebate."
>
  <!-- Hero -->
  <section>
    <div class="max-w-body mx-auto px-4 py-16 md:py-20">
      <p class="text-[13px] font-semibold uppercase tracking-[0.13em] text-primary">Costs &amp; rebates</p>
      <h1 class="font-display font-semibold text-[32px] md:text-[40px] tracking-[-0.02em] text-heading mt-3 mb-4">Cost Calculator</h1>
      <p class="text-lg text-body">
        Estimate what you'll pay out-of-pocket for a mental health session after the Medicare rebate.
      </p>
    </div>
  </section>

  <!-- Calculator -->
  <section>
    <div class="max-w-4xl mx-auto px-4 pb-16 md:pb-20">
      <CostCalculator />
      <p class="text-sm text-meta-sage text-center mt-6">Rebate figures last checked: {lastVerified}</p>
    </div>
  </section>

  <!-- Explanation -->
  <section>
    <div class="max-w-body mx-auto px-4 py-16 md:py-20">
      <h2 class="font-display font-semibold text-[24px] md:text-[28px] tracking-[-0.02em] text-heading mb-6">How Medicare Rebates Work</h2>
      <div class="space-y-5 text-body">
        <p>
          With a valid <a href="/pathway/#through-gp" class="font-semibold text-primary underline underline-offset-2">Mental Health Care Plan (MHCP)</a> and GP referral,
          Medicare pays back a fixed amount per session &mdash; the <strong>rebate</strong>. The gap between the
          session fee and the rebate is what you pay out of pocket.
        </p>
        <p>
          Your first 6 sessions in a calendar year are automatic. After that, your GP does a brief review before
          Medicare will fund sessions 7 to 10.
        </p>
        <p>
          Some psychologists <strong>bulk-bill</strong>, charging only the Medicare rebate amount so there's no gap
          to pay &mdash; though bulk-billing practitioners often have longer wait times.
        </p>
      </div>
    </div>
  </section>

  <!-- Next steps -->
  <section class="bg-paper-cream border-t border-pencil">
    <div class="max-w-body mx-auto px-4 py-16 md:py-20 text-center">
      <h2 class="font-display font-semibold text-[22px] md:text-[24px] tracking-[-0.02em] text-heading mb-6">Know your numbers? Here's what's next.</h2>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/tips/what-to-say-to-gp/"
          class="inline-flex min-h-11 items-center justify-center gap-1.5 rounded-[10px] border border-ink-green/16 bg-transparent px-6 py-3 font-semibold text-heading hover:bg-row-hover transition-colors duration-150"
        >
          What to say to your GP
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
        </a>
        <Button href="/pathway/" size="md" class="gap-1.5">
          See the full pathway
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>
